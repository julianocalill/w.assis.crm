            loadOportunidadesDoContato: async (contatoId) => {
                const tbody = document.getElementById('tbody-historico-ops');
                app.historicoOpsLastContatoId = contatoId;
                const currentOpId = String(document.getElementById('opId')?.value || '');
                const fmtDateBR = (iso) => {
                    if (!iso || typeof iso !== 'string') return '-';
                    const t = iso.trim().split('T')[0];
                    const parts = t.split('-');
                    if (parts.length !== 3) return '-';
                    const y = parseInt(parts[0], 10);
                    const mo = parseInt(parts[1], 10);
                    const da = parseInt(parts[2], 10);
                    if (Number.isNaN(y) || Number.isNaN(mo) || Number.isNaN(da)) return '-';
                    const dt = new Date(y, mo - 1, da);
                    if (dt.getFullYear() !== y || dt.getMonth() !== mo - 1 || dt.getDate() !== da) return '-';
                    return dt.toLocaleDateString('pt-BR');
                };
                const dateSortValue = (iso) => {
                    if (!iso || typeof iso !== 'string') return Number.NEGATIVE_INFINITY;
                    const t = iso.trim().split('T')[0];
                    const parts = t.split('-');
                    if (parts.length !== 3) return Number.NEGATIVE_INFINITY;
                    const y = parseInt(parts[0], 10);
                    const mo = parseInt(parts[1], 10);
                    const da = parseInt(parts[2], 10);
                    if (Number.isNaN(y) || Number.isNaN(mo) || Number.isNaN(da)) return Number.NEGATIVE_INFINITY;
                    return Date.UTC(y, mo - 1, da);
                };
                tbody.innerHTML = '<tr><td colspan="7" class="py-10 text-center"><i class="fa-solid fa-spinner fa-spin text-textMuted text-xl"></i> Buscando...</td></tr>';
                
                try {
                    const cid = String(contatoId);
                    const {data} = await app.sb.from('oportunidades').select('*').or(`contato_id.eq.${cid},responsavel_id.eq.${cid}`).order('criado_em', {ascending:false});
                    const visibleData = (data || []).filter(o => o.excluido !== true);
                    app.updateHistoricoOpsSortIcons();
                    if (!visibleData.length) { 
                        tbody.innerHTML = '<tr><td colspan="7" class="py-10 text-center text-textMuted font-medium">Nenhuma oportunidade anterior encontrada para este cliente.</td></tr>'; 
                        return; 
                    }
                    const sortedData = [...visibleData].sort((a, b) => {
                        const sortKey = app.historicoOpsSortKey;
                        const dir = app.historicoOpsSortAsc ? 1 : -1;
                        const corretorA = app.corretores.find(c => c.id === a.corretor_id)?.nome_completo || 'Corretor';
                        const corretorB = app.corretores.find(c => c.id === b.corretor_id)?.nome_completo || 'Corretor';
                        const valA = (() => {
                            switch (sortKey) {
                                case 'vigencia': return dateSortValue(a.vigencia);
                                case 'ramo': return (ui.oportunidadeRamoExibicao(a) || '-').toLowerCase();
                                case 'tipo': return (a.tipo_seguro || '-').toLowerCase();
                                case 'etapa': return (a.etapa_nome || '-').toLowerCase();
                                case 'produtor': return corretorA.toLowerCase();
                                case 'retorno': return dateSortValue(a.retorno);
                                case 'status': return (a.status || '-').toLowerCase();
                                default: return '';
                            }
                        })();
                        const valB = (() => {
                            switch (sortKey) {
                                case 'vigencia': return dateSortValue(b.vigencia);
                                case 'ramo': return (ui.oportunidadeRamoExibicao(b) || '-').toLowerCase();
                                case 'tipo': return (b.tipo_seguro || '-').toLowerCase();
                                case 'etapa': return (b.etapa_nome || '-').toLowerCase();
                                case 'produtor': return corretorB.toLowerCase();
                                case 'retorno': return dateSortValue(b.retorno);
                                case 'status': return (b.status || '-').toLowerCase();
                                default: return '';
                            }
                        })();
                        if (typeof valA === 'number' && typeof valB === 'number') {
                            return (valA - valB) * dir;
                        }
                        return String(valA).localeCompare(String(valB), 'pt-BR', { sensitivity: 'base' }) * dir;
                    });

                    tbody.innerHTML = sortedData.map(o => {
                        const ramosText = ui.oportunidadeRamoExibicao(o);
                        const isCurrent = currentOpId && String(o.id) === currentOpId;
                        
                        const corretorNome = app.corretores.find(c => c.id === o.corretor_id)?.nome_completo || 'Corretor';
                        
                        let statusColor = 'text-primary';
                        if (o.status === 'ganho') {
                            statusColor = 'text-emerald-500';
                        }
                        if (o.status === 'perdido') {
                            statusColor = 'text-red-500';
                        }
                        const rowClass = isCurrent
                            ? 'bg-blue-50/70 ring-1 ring-inset ring-blue-200'
                            : 'hover:bg-slate-50';
                        const etapaNome = o.etapa_nome || '-';
                        const atualBadge = isCurrent
                            ? '<span class="ml-2 inline-flex items-center rounded-full bg-blue-100 text-blue-700 border border-blue-200 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wider">Atual</span>'
                            : '';

                        return `
                            <tr class="transition cursor-pointer ${rowClass}" onclick="app.openGlobalSearchOportunidade(${o.id})">
                                <td class="py-4 text-textMuted">${fmtDateBR(o.vigencia)}${atualBadge}</td>
                                <td class="py-4 text-textMain font-bold text-xs">${ramosText}</td>
                                <td class="py-4 text-textMuted">${o.tipo_seguro || '-'}</td>
                                <td class="py-4 text-xs text-textMuted"><span class="inline-block bg-blue-50 text-blue-700 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">${etapaNome}</span></td>
                                <td class="py-4 text-xs text-textMuted">${corretorNome}</td>
                                <td class="py-4 text-textMuted">${fmtDateBR(o.retorno)}</td>
                                <td class="py-4 font-bold ${statusColor} uppercase text-[10px] tracking-wider">${o.status}</td>
                            </tr>
                        `;
                    }).join('');
                } catch (e) {
                    tbody.innerHTML = '<tr><td colspan="7" class="py-10 text-center text-red-500">Erro ao buscar histórico do cliente.</td></tr>'; 
                }
            },

