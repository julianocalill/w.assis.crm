            updateDashboard: () => {
                const src = (app._metricsOps && app._metricsOps.length) ? app._metricsOps : app.oportunidades;
                const ops = src.filter(o => !o.excluido);
                
                document.getElementById('kpi-count').innerText = ops.length;
                
                let premioTotal = 0; 
                let receitaTotal = 0;
                let somaComissoes = 0;
                let numProdutos = 0;

                ops.forEach(o => {
                    const oPrem = parseFloat(o.premio_liquido) || 0;
                    const oCom = parseFloat(o.comissao_percentual) || 0;
                    const oAg = parseFloat(o.agenciamento_percentual) || 0;
                    const temFlat = (o.ramo_seguro != null && String(o.ramo_seguro).trim() !== '') || oPrem !== 0 || oCom !== 0 || oAg !== 0;
                    if (temFlat || !o.produtos || !Array.isArray(o.produtos) || o.produtos.length === 0) {
                        premioTotal += oPrem;
                        receitaTotal += oPrem * ((oCom + oAg) / 100);
                        if (oPrem > 0) {
                            somaComissoes += (oCom + oAg);
                            numProdutos++;
                        }
                    } else {
                        o.produtos.forEach(p => {
                            const pPrem = parseFloat(p.premio) || 0;
                            const pCom = parseFloat(p.comissao) || 0;
                            const pAg = parseFloat(p.agenciamento) || 0;
                            premioTotal += pPrem;
                            receitaTotal += pPrem * ((pCom + pAg) / 100);
                            if (pPrem > 0) {
                                somaComissoes += (pCom + pAg);
                                numProdutos++;
                            }
                        });
                    }
                });
                
                const ticketMedio = ops.length > 0 ? (premioTotal / ops.length) : 0;
                const comissaoMedia = numProdutos > 0 ? (somaComissoes / numProdutos) : 0;
                
                document.getElementById('kpi-premio').innerText = formatBRL(premioTotal);
                document.getElementById('kpi-receita').innerText = formatBRL(receitaTotal);
                document.getElementById('kpi-ticket').innerText = formatBRL(ticketMedio);
