                const tituloCardRaw = (ui.tituloOportunidadeExibicao(d) || '').trim();
                const nomeSegLinha = (ui.nomeSeguradoExibicao(d) || '').trim();
                const subSegurado = (tituloCardRaw && nomeSegLinha && window.app.normalizeText(tituloCardRaw) !== window.app.normalizeText(nomeSegLinha))
