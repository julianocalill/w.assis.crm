            normalizeText: (v) => (v || '').toString().trim().toLowerCase(),

            normalizeSearchText: (v) => (v || '')
                .toString()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim()
                .toLowerCase(),

            scoreContatoByQuery: (contato, rawQuery) => {
                const qText = app.normalizeSearchText(rawQuery);
                const qDigits = app.normalizeDigits(rawQuery);
                if (!qText && !qDigits) {
                    return 0;
                }

                const nome = app.normalizeSearchText(contato?.nome);
                const doc = app.normalizeDigits(contato?.documento);
                const email = app.normalizeSearchText(contato?.email);
                const telefone = app.normalizeDigits(contato?.telefone);
                let score = 0;

                if (qDigits) {
                    if ((qDigits.length === 11 || qDigits.length === 14) && doc === qDigits) score = Math.max(score, 130);
                    else if (doc && doc.startsWith(qDigits)) score = Math.max(score, 110);
                    else if (doc && doc.includes(qDigits)) score = Math.max(score, 95);

                    if (telefone) {
                        if (telefone === qDigits) score = Math.max(score, 120);
                        else if (telefone.startsWith(qDigits)) score = Math.max(score, 105);
                        else if (telefone.includes(qDigits)) score = Math.max(score, 90);
                    }
                }

                if (qText) {
                    if (nome === qText) score = Math.max(score, 125);
                    else if (nome.startsWith(qText)) score = Math.max(score, 108);
                    else if (nome.includes(qText)) score = Math.max(score, 92);

                    if (email) {
                        if (email === qText) score = Math.max(score, 115);
                        else if (email.startsWith(qText)) score = Math.max(score, 100);
                        else if (email.includes(qText)) score = Math.max(score, 88);
                    }
                }

                return score;
            },

            getFilteredContatos: () => {
                const query = app.contatosSearchTerm || '';
                if (!query.trim()) {
                    return [...(app.contatos || [])].sort((a, b) => (a.nome || '').localeCompare(b.nome || '', 'pt-BR'));
                }

                const scoredContatos = (app.contatos || [])
                    .map(contato => ({ contato, score: app.scoreContatoByQuery(contato, query) }))
                    .sort((a, b) => b.score - a.score || (a.contato.nome || '').localeCompare(b.contato.nome || '', 'pt-BR'));
                const filteredContatos = scoredContatos.filter(item => item.score > 0);
                return filteredContatos.map(item => item.contato);
            },

