            createCard: (d) => {
                const el = document.createElement('div');
                
                let colorClasses = 'border-blue-200 bg-white';
                
                if (d.retorno && d.status === 'aberto') {
                    const hoje = new Date();
                    hoje.setHours(0,0,0,0);
                    
                    const [ano, mes, dia] = d.retorno.split('-');
                    const dataRet = new Date(ano, mes - 1, dia);
                    dataRet.setHours(0,0,0,0);
                    
                    if (dataRet < hoje) {
                        colorClasses = 'border-red-400 bg-red-50';
                    } else if (dataRet.getTime() === hoje.getTime()) {
                        colorClasses = 'border-blue-300 bg-blue-50';
                    }
                }
                
                el.className = `p-3 rounded-xl border ${colorClasses} shadow-sm cursor-pointer hover:shadow-md transition group w-full h-[126px] min-h-[126px] max-h-[126px] flex flex-col overflow-hidden`;
                el.dataset.id = d.id;
                el.onclick = () => window.ui.editDealById(d.id);
                
                const ramosText = ui.oportunidadeRamoExibicao(d);
                const val = ui.oportunidadeReceitaEstimada(d);

                let rightBadge = '';
                if (d.status === 'aberto') {
                    const dateRows = [];
                    if (d.retorno) {
                        dateRows.push({ kind: 'tarefa', label: 'TAREFA', value: formatKanbanRetorno(d.retorno) });
                    }
                    if (d.vigencia) {
                        dateRows.push({ kind: 'vigencia', label: 'VIGÊNCIA', value: formatKanbanRetorno(d.vigencia) });
                    }
                    if (dateRows.length > 0) {
                        const titleTxt = dateRows.map(r => `${r.label} ${r.value}`).join(' | ').replace(/"/g, '&quot;');
                        const dateRowsHtml = dateRows.map((r) => {
                            const iconClass = r.kind === 'vigencia'
                                ? 'fa-regular fa-calendar-days shrink-0 text-emerald-700'
                                : 'fa-solid fa-bell shrink-0 text-blue-700';
                            const rowWrap = r.kind === 'vigencia'
                                ? 'border-l-2 border-emerald-500 pl-1.5 bg-emerald-50/70'
                                : 'border-l-2 border-blue-500 pl-1.5 bg-blue-50/70';
                            return `<span class="flex items-center gap-1 min-w-0 w-full ${rowWrap} py-0.5 leading-tight">
                                    <i class="${iconClass}"></i>
                                    <span class="uppercase shrink-0">${r.label}</span>
                                    <span class="truncate">${r.value}</span>
                                </span>`;
                        }).join('');
                        rightBadge = `
                            <span class="text-[8px] font-bold px-2 py-1 rounded-md bg-orange-100 text-orange-800 flex flex-col gap-0 items-stretch max-w-[55%] shrink-0 leading-tight overflow-hidden" title="${titleTxt}">
                                ${dateRowsHtml}
                            </span>`;
                    }
                }

                const vendedorNome = (d.nome_corretor || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
                const seguradoNome = (d.nome_segurado || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
                const ramosEsc = (ramosText || '').replace(/"/g, '&quot;');
                const segEsc = (d.seguradora || '-').replace(/&/g, '&amp;').replace(/</g, '&lt;');
                let avatarCell = '';
                if (d.avatar_corretor) {
                    const url = String(d.avatar_corretor).replace(/'/g, "\\'");
                    avatarCell = `<div class="w-8 h-8 rounded-full border border-border shrink-0 bg-slate-200 bg-cover bg-center" style="background-image:url('${url}')"></div>`;
                } else {
                    avatarCell = `<div class="w-8 h-8 rounded-full border border-border shrink-0 bg-slate-200 flex items-center justify-center"><i class="fa-solid fa-user text-[10px] text-textMuted"></i></div>`;
                }

                el.innerHTML = `
                    <div class="flex justify-between items-start gap-1 shrink-0 mb-1.5">
                        <span class="text-[8px] font-bold uppercase px-2 py-0.5 rounded-md bg-slate-100 text-slate-700 truncate max-w-[45%]" title="${ramosEsc}">${ramosText}</span>
                        ${rightBadge}
                    </div>
                    <h4 class="font-bold text-textMain text-sm leading-snug truncate shrink-0">${seguradoNome}</h4>
                    <div class="border-t border-slate-200 shrink-0 my-1.5"></div>
                    <div class="flex justify-between items-end gap-2 min-h-0 flex-1 pt-0.5">
                        <div class="flex items-end gap-2 min-w-0">
                            ${avatarCell}
                            <div class="min-w-0 text-left">
                                <p class="text-[9px] text-textMain font-semibold truncate leading-tight">Vendedor: ${vendedorNome || '—'}</p>
                                <p class="text-[8px] text-textMuted flex items-center gap-1 truncate leading-tight mt-0.5">
                                    <i class="fa-regular fa-building shrink-0"></i><span class="truncate">${segEsc}</span>
                                </p>
                            </div>
                        </div>
                        <div class="text-right shrink-0">
                            <p class="text-[10px] font-bold text-emerald-600 tracking-wide leading-none mb-0.5">Comissão do negócio</p>
                            <p class="font-extrabold text-emerald-600 text-xs leading-none">${formatBRL(val)}</p>
                        </div>
                    </div>
                `;
                return el;
            },

            renderListTable: () => {
