                        </button>
                    `;
                    box.classList.remove('hidden');
                    status.innerText = 'Nenhum cliente localizado. Preencha os campos para novo cadastro.';
                    return;
                }

                box.innerHTML = resultados.map(c => {
                    const nome = app.escapeHtml(c.nome || 'Sem nome');
                    const doc = c.documento ? ui.maskDoc(c.documento) : '-';
                    const tel = c.telefone ? ui.maskPhone(c.telefone) : '-';
                    return `
                        <button type="button" onclick="app.selecionarContatoModal('${role}', ${c.id})" class="w-full text-left px-4 py-3 border-b border-slate-100 hover:bg-slate-50 transition">
