                            <select onchange="ui.updateProduto(${index}, 'tipo', this.value)" class="w-full border border-border rounded px-2 py-1.5 text-xs outline-none focus:border-primary">
                                <option value="Novo" ${p.tipo==='Novo'?'selected':''}>Novo</option>
                                <option value="Renovação" ${p.tipo==='Renovação'?'selected':''}>Renovação</option>
                            </select>
                        </div>
                        <div class="w-24">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Prêmio (R$)</label>
                            <input type="number" step="0.01" placeholder="Prêmio Liq" value="${p.premio||''}" oninput="ui.updateProduto(${index}, 'premio', this.value)" class="w-full border border-border rounded px-2 py-1.5 text-xs outline-none focus:border-primary text-center">
                        </div>
                        <div class="w-20">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">% Comis.</label>
                            <input type="number" step="0.01" placeholder="% Com." value="${p.comissao||''}" oninput="ui.updateProduto(${index}, 'comissao', this.value)" class="w-full border border-border rounded px-2 py-1.5 text-xs outline-none focus:border-primary text-center">
                        </div>
                        <div class="w-20">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">% Agenc.</label>
                            <input type="number" step="0.01" placeholder="% Agen." value="${p.agenciamento||''}" oninput="ui.updateProduto(${index}, 'agenciamento', this.value)" class="w-full border border-border rounded px-2 py-1.5 text-xs outline-none focus:border-primary text-center">
                        </div>
                        <div class="flex-1 text-right pt-4 pr-2">
                            <div class="text-sm font-bold text-emerald-600 receita-text">${formatBRL(receita)}</div>
                        </div>
                        <button type="button" onclick="ui.removeProduto(${index})" class="text-textMuted hover:text-red-500 transition px-2 pt-4 outline-none" title="Remover Produto">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    `;
                }).join('');
                
                ui.calcTotalProdutos();
