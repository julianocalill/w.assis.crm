            createCard: (d) => {
                const el = document.createElement('div');
                
                let colorClasses = 'border-border bg-white';
                let iconClass = 'text-textMuted';
                
                if (d.retorno && d.status === 'aberto') {
                    const hoje = new Date();
                    hoje.setHours(0,0,0,0);
                    
                    const [ano, mes, dia] = d.retorno.split('-');
                    const dataRet = new Date(ano, mes - 1, dia);
                    dataRet.setHours(0,0,0,0);
                    
                    if (dataRet < hoje) {
                        colorClasses = 'border-red-400 bg-red-50';
                        iconClass = 'text-red-500';
                    } else if (dataRet.getTime() === hoje.getTime()) {
                        colorClasses = 'border-yellow-400 bg-yellow-50';
                        iconClass = 'text-yellow-500';
                    }
                }
                
                el.className = `p-4 rounded-xl border ${colorClasses} shadow-sm cursor-pointer hover:shadow-md transition group w-full`;
                el.dataset.id = d.id;
                el.onclick = () => window.ui.editDealById(d.id);
                
                let ramosText = d.ramo_seguro || 'Não definido';
                let val = 0;
                
                if (d.produtos && Array.isArray(d.produtos) && d.produtos.length > 0) {
                    ramosText = d.produtos.map(p => p.ramo).join(', ');
                    d.produtos.forEach(p => {
                        const pPremio = parseFloat(p.premio) || 0;
                        const pComissao = parseFloat(p.comissao) || 0;
                        const pAgen = parseFloat(p.agenciamento) || 0;
                        val += pPremio * ((pComissao + pAgen) / 100);
                    });
                } else {
                    const dPremio = parseFloat(d.premio_liquido) || 0;
                    const dComissao = parseFloat(d.comissao_percentual) || 0;
                    const dAgen = parseFloat(d.agenciamento_percentual) || 0;
                    val = dPremio * ((dComissao + dAgen) / 100);
                }
                
                let iconStatus = `<i class="fa-regular fa-clock ${iconClass}"></i>`;
                if (d.status === 'ganho') {
                    iconStatus = '<i class="fa-solid fa-check text-emerald-500 text-lg"></i>';
                }
                if (d.status === 'perdido') {
                    iconStatus = '<i class="fa-solid fa-x text-red-500 text-lg"></i>';
