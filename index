            loadTimeline: async (opId) => {
                const container = document.getElementById('timeline-container'); 
                container.innerHTML = '<div class="py-4"><i class="fa-solid fa-spinner fa-spin text-textMuted"></i> Carregando histórico...</div>';
                
                try {
                    const {data} = await app.sb.from('historico_oportunidades').select('*').eq('oportunidade_id', opId).eq('is_log', false).order('criado_em', {ascending:false});
                    
                    if (!data || data.length === 0) { 
                        container.innerHTML = '<p class="text-xs text-textMuted">Nenhum evento registrado ainda.</p>'; 
                        return; 
                    }
                    
                    container.innerHTML = data.map(h => {
                        let cor = 'bg-slate-400';
                        if (h.tipo === 'Observação') {
                            cor = 'bg-purple-500';
                        }
                        if (h.tipo === 'Movimentação') {
                            cor = 'bg-blue-500';
                        }
                        if (h.tipo === 'Criação') {
                            cor = 'bg-emerald-500';
                        }
                        if (h.tipo === 'Exclusão') {
                            cor = 'bg-red-500';
                        }
                        if (h.tipo === 'Arquivo Anexado') {
                            cor = 'bg-orange-500';
                        }

                        const quando = formatHistoricoDataHora(h.criado_em);
                        const autorCor = h.criado_por ? app.corretores.find(c => String(c.id) === String(h.criado_por)) : null;
                        const autorNome = (autorCor?.nome_completo || '').trim();
                        const metaLinha = autorNome
                            ? `${escHtml(h.tipo)} - ${escHtml(quando)} · por ${escHtml(autorNome)}`
                            : `${escHtml(h.tipo)} - ${escHtml(quando)}`;

                        return `
                        <div class="relative mb-6">
                            <span class="absolute -left-[29px] ${cor} w-3 h-3 rounded-full ring-4 ring-slate-100 shadow-sm"></span>
                            <p class="text-[10px] text-textMuted font-bold mb-0.5 uppercase tracking-wider">${metaLinha}</p>
                            <p class="text-sm text-textMain bg-slate-50 p-3 rounded-lg border border-slate-100 shadow-sm mt-1">${escHtml(h.descricao)}</p>
                        </div>
                        `;
                    }).join('');
                } catch(e) {
                    container.innerHTML = '<p class="text-xs text-red-500">Erro ao carregar histórico.</p>'; 
                }
            },

            loadLogs: async (opId) => {
                const container = document.getElementById('logs-container');
                if (!container) {
                    return;
                }
