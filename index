                    const agenciamento = parseFloat(p.agenciamento) || 0;
                    const receita = premio * ((comissao + agenciamento) / 100);

                    let selectRamoFormatado = ramoOptionsHtml;
                    
                    if (p.ramo) {
                        selectRamoFormatado = selectRamoFormatado.replace(`value="${p.ramo}"`, `value="${p.ramo}" selected`);
                    }

                    return `
                    <div class="flex gap-3 items-center bg-white p-3 rounded-lg border border-border relative shadow-sm">
                        <div class="w-1/4">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Ramo</label>
