            createCard: (d) => {
                const el = document.createElement('div');
                
                let colorClasses = 'border-blue-200 bg-white';
                
                if (d.retorno && d.status === 'aberto') {
                    const hoje = new Date();
                    hoje.setHours(0,0,0,0);
                    
                    const [ano, mes, dia] = d.retorno.split('-');
                    const dataRet = new Date(ano, mes - 1, dia);
                    dataRet.setHours(0,0,0,0);
                    
                    if (dataRet < hoje) {
                        colorClasses = 'border-red-400 bg-red-50';
                    } else if (dataRet.getTime() === hoje.getTime()) {
                        colorClasses = 'border-blue-300 bg-blue-50';
                    }
                }
                
                el.className = `p-3 rounded-xl border ${colorClasses} shadow-sm cursor-pointer hover:shadow-md transition group w-full min-h-[126px] flex flex-col`;
                el.dataset.id = d.id;
                el.onclick = () => window.ui.editDealById(d.id);
                
