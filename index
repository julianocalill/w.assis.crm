<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>W.Assis CRM | Seguros</title>
    
    <link rel="icon" type="image/png" href="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 
                        primary: '#0263E0', 
                        surface: '#FFFFFF', 
                        bg: '#F8FAFC', 
                        border: '#E2E8F0', 
                        textMain: '#1E293B', 
                        textMuted: '#64748B', 
                        danger: '#DC2626' 
                    },
                    fontFamily: { 
                        sans: ['Inter', 'sans-serif'] 
                    }
                }
            }
        }
    </script>

    <style>
        body { 
            background-color: #F8FAFC; 
            color: #1E293B; 
            font-family: 'Inter', sans-serif; 
        }
        
        /* Barra de Rolagem (Scrollbars) */
        ::-webkit-scrollbar { 
            width: 8px; 
            height: 8px; 
        }
        
        ::-webkit-scrollbar-thumb { 
            background: #CBD5E1; 
            border-radius: 4px; 
        }
        
        ::-webkit-scrollbar-track { 
            background: transparent; 
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb { 
            background: #94A3B8; 
        }
        
        /* Efeitos visuais do Kanban */
        .ghost-card { 
            background: #EFF6FF; 
            border: 2px dashed #0263E0; 
            opacity: 0.7; 
        }
        
        .handle { 
            cursor: grab; 
        }
        
        .handle:active { 
            cursor: grabbing; 
        }

        /* Configuração das Colunas Dinâmicas do Kanban */
        .kanban-col { 
            min-width: 320px; 
            width: 320px; 
            flex-shrink: 0; 
            transition: width 0.3s ease, min-width 0.3s ease; 
        }
        
        .kanban-col.collapsed { 
            min-width: 64px; 
            width: 64px; 
            background-color: #F1F5F9; 
            border: 1px dashed #CBD5E1; 
            border-radius: 1rem; 
        }
        
        .kanban-col.collapsed .col-header-full, 
        .kanban-col.collapsed .kanban-list { 
            display: none !important; 
        }
        
        .col-header-collapsed { 
            display: none; 
        }
        
        .kanban-col.collapsed .col-header-collapsed { 
            display: flex; 
        }
        
        .vertical-text { 
            writing-mode: vertical-rl; 
            transform: rotate(180deg); 
            letter-spacing: 0.05em; 
        }

        /* Navegação da Sidebar Esquerda */
        .nav-item.active { 
            background-color: #0263E0; 
            color: #FFFFFF; 
            font-weight: 600; 
        }
        
        .nav-item.active i { 
            color: #FFFFFF; 
        }
        
        /* Estilização das Abas Superiores do Modal do Card */
        .modal-tab-btn { 
            padding-bottom: 0.5rem; 
            color: #64748B; 
            font-weight: 500; 
            font-size: 0.8rem; 
            border-bottom: 2px solid transparent; 
            transition: all 0.2s; 
            cursor: pointer; 
            background: none; 
        }
        
        .modal-tab-btn.active { 
            color: #DC2626; 
            font-weight: 700; 
            border-bottom-color: #DC2626; 
        }
        
        .modal-tab-btn:hover:not(.active) { 
            color: #1E293B; 
        }
        
        /* Estilização das Abas Laterais do Modal de Configurações */
        .settings-tab-btn {
            width: 100%; 
            text-align: left; 
            padding: 0.75rem 1rem; 
            border-radius: 0.5rem; 
            color: #64748B; 
            font-weight: 600; 
            transition: all 0.2s; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            gap: 0.75rem;
        }
        
        .settings-tab-btn.active { 
            background-color: #EFF6FF; 
            color: #0263E0; 
        }
        
        .settings-tab-btn:hover:not(.active) { 
            background-color: #F8FAFC; 
            color: #1E293B; 
        }

        /* Botão de Upload de Arquivos Personalizado */
        input[type="file"]::file-selector-button { 
            background-color: #0263E0; 
            color: white; 
            border: none; 
            padding: 0.5rem 1rem; 
            border-radius: 0.5rem; 
            font-weight: 600; 
            cursor: pointer; 
            transition: background-color 0.2s; 
        }
        
        input[type="file"]::file-selector-button:hover { 
            background-color: #1d4ed8; 
        }
        
        /* Ajustes Visuais BI (Sprint 3) */
        .bi-card {
            border-left: 4px solid #0263E0;
        }
        .bi-card-emerald {
            border-left: 4px solid #10B981;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden text-sm">

    <div id="loginOverlay" class="fixed inset-0 bg-bg z-[200] flex items-center justify-center">
        <div class="bg-surface p-10 rounded-2xl shadow-xl border border-border w-[400px]">
            <div class="flex justify-center mb-8">
                <img src="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png" alt="W.Assis Seguros" class="h-12 object-contain">
            </div>
            
            <form id="loginForm" onsubmit="event.preventDefault(); app.login(event); return false;" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-textMuted mb-1 uppercase tracking-wider">E-mail Corporativo</label>
                    <input type="email" id="loginEmail" required class="w-full border border-border rounded-lg p-3 outline-none focus:border-primary transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-textMuted mb-1 uppercase tracking-wider">Senha</label>
                    <input type="password" id="loginPassword" required class="w-full border border-border rounded-lg p-3 outline-none focus:border-primary transition">
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-blue-700 text-white font-bold py-3 rounded-lg shadow-lg mt-2 transition">
                    Entrar no Sistema
                </button>
            </form>
        </div>
    </div>

    <aside class="w-64 bg-surface border-r border-border flex flex-col h-full z-20 shadow-sm shrink-0">
        <div class="h-20 flex items-center justify-center px-6 border-b border-border">
            <img src="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png" alt="W.Assis Seguros" class="h-8 object-contain">
        </div>
        
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <button onclick="app.navigate('dashboard')" id="nav-dashboard" class="nav-item active flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-chart-pie w-5 text-center"></i> Analytics
            </button>
            
            <button onclick="app.navigate('oportunidades')" id="nav-oportunidades" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-handshake w-5 text-center"></i> Oportunidades
            </button>
            
            <button onclick="app.navigate('contatos')" id="nav-contatos" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-regular fa-address-book w-5 text-center"></i> Contatos
            </button>
            
            <button onclick="app.navigate('segurados')" id="nav-segurados" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-shield-halved w-5 text-center"></i> Segurados Ativos
            </button>
        </nav>
        
        <div class="p-4 border-t border-border">
            <button onclick="ui.openSettingsModal()" class="flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-gear w-5 text-center"></i> Configurações
            </button>
            
            <button onclick="app.logout()" class="flex items-center gap-3 w-full px-4 py-3 mt-2 rounded-xl text-red-500 hover:bg-red-50 transition">
                <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center"></i> Sair
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full bg-bg relative min-w-0">
        
        <header class="h-20 bg-surface border-b border-border px-8 flex justify-between items-center z-10 shadow-sm shrink-0">
            <div class="relative w-96 hidden md:block">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-textMuted"></i>
                <input type="text" placeholder="Buscar no sistema..." class="w-full bg-slate-100 border border-transparent focus:border-border rounded-full py-2.5 pl-11 pr-4 text-sm outline-none transition focus:bg-white">
            </div>
            
            <div class="flex items-center gap-6 ml-auto">
                <div class="flex items-center gap-3 text-right cursor-pointer hover:bg-slate-50 p-2 rounded-xl transition" onclick="ui.openProfileModal()">
                    <div class="hidden md:block">
                        <p id="user-name" class="text-sm font-bold text-textMain leading-tight">Carregando...</p>
                        <p id="user-role" class="text-[10px] font-semibold text-textMuted uppercase tracking-wider">Meu Perfil</p>
                    </div>
                    <div id="user-avatar" class="w-10 h-10 rounded-full bg-slate-200 border-2 border-white shadow-sm flex items-center justify-center text-primary font-bold bg-cover bg-center">
                        <i class="fa-solid fa-user"></i>
                    </div>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-hidden relative">
            
            <div id="view-dashboard" class="h-full overflow-y-auto p-8">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-textMain">Painel Executivo</h2>
                        <p class="text-textMuted mt-1"><span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider mr-2">Tempo Real</span> Relatórios e indicadores consolidados.</p>
                    </div>
                    
                    <select id="analytics-pipeline-selector" onchange="app.switchPipeline(this.value)" class="bg-white border border-border rounded-lg px-4 py-2 text-sm text-textMain font-bold outline-none focus:border-primary shadow-sm min-w-[200px]">
                        </select>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-briefcase text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Volume de Negócios</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-count">0</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Oportunidades ativas no funil</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-chart-line text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Prêmio Líquido Total</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-premio">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Soma dos prêmios em negociação</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card-emerald relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-emerald-100"><i class="fa-solid fa-sack-dollar text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-emerald-600 uppercase tracking-wider">Receita Estimada</p>
                        <h3 class="text-3xl font-extrabold text-emerald-600 mt-2" id="kpi-receita">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Previsão total de comissionamento</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-calculator text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Ticket Médio (Prêmio)</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-ticket">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium" id="kpi-comissao-perc">Comissão Média: 0%</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 pb-10">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border lg:col-span-2">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3">Distribuição do Funil</h3>
                        <div class="h-64 relative">
                            <canvas id="chartFunil"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3">Share de Produtos</h3>
                        <div class="h-64 relative flex justify-center">
                            <canvas id="chartRamo"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border lg:col-span-3">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3"><i class="fa-solid fa-trophy text-emerald-500 mr-2"></i> Últimos Fechamentos (Top 5)</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-slate-50 text-[10px] text-textMuted uppercase font-bold border-b border-border">
                                    <tr>
                                        <th class="px-4 py-3">Data</th>
                                        <th class="px-4 py-3">Segurado</th>
                                        <th class="px-4 py-3">Ramo</th>
                                        <th class="px-4 py-3">Produtor</th>
                                        <th class="px-4 py-3 text-right">Receita Gerada</th>
                                    </tr>
                                </thead>
                                <tbody id="dash-recentes-tbody" class="divide-y divide-border text-sm">
                                    </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div id="view-oportunidades" class="h-full flex flex-col hidden">
                
                <div class="px-6 py-4 bg-surface border-b border-border shrink-0">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-extrabold text-textMain">Funil de Vendas</h2>
                        
                        <div class="flex items-center gap-3">
                            <select id="pipeline-selector" onchange="app.switchPipeline(this.value)" class="bg-slate-50 border border-border rounded-lg px-3 py-1.5 text-xs text-textMain outline-none min-w-[150px]">
                                </select>
                            
                            <div class="flex bg-slate-100 p-1 rounded-lg border border-border">
                                <button onclick="ui.toggleView('lista')" id="btn-view-lista" class="px-4 py-1.5 rounded-md text-textMuted font-medium text-xs flex items-center gap-2 transition">
                                    <i class="fa-solid fa-list"></i> Lista
                                </button>
                                
                                <button onclick="ui.toggleView('kanban')" id="btn-view-kanban" class="px-4 py-1.5 rounded-md bg-white shadow-sm text-primary font-bold text-xs flex items-center gap-2 transition">
                                    <i class="fa-solid fa-grip-vertical"></i> Kanban
                                </button>
                            </div>
                            
                            <button onclick="ui.openDealModal()" class="bg-primary hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-bold shadow-sm transition text-xs flex items-center gap-2">
                                <i class="fa-solid fa-plus"></i> Nova Oportunidade
                            </button>
                        </div>
                    </div>
                    
                    <div class="bg-slate-50 p-3 rounded-lg border border-border flex flex-wrap gap-3 items-end shadow-inner">
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Data Inicial</label>
                            <input type="date" id="filter-data-ini" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Data Final</label>
                            <input type="date" id="filter-data-fim" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Ramo</label>
                            <select id="filter-ramo" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                                </select>
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Origem</label>
                            <select id="filter-origem" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                                </select>
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Profissional</label>
                            <select id="filter-corretor" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white transition-colors">
                                <option value="">Todos os Usuários</option>
                                </select>
                        </div>
                        
                        <button onclick="app.loadData()" class="bg-slate-800 text-white px-6 py-2 rounded text-xs font-bold hover:bg-slate-700 transition shadow-sm h-[34px]">
                            Filtrar
                        </button>
                    </div>
                </div>
                
                <div id="board-kanban" class="flex-1 overflow-x-auto overflow-y-hidden flex p-6 gap-4 items-start custom-scrollbar bg-slate-100/50">
                    </div>
                
                <div id="board-lista" class="hidden flex-1 overflow-y-auto p-6 custom-scrollbar bg-bg">
                    <div class="bg-surface border border-border rounded-xl shadow-sm overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-slate-50 text-xs text-textMuted uppercase font-bold border-b border-border">
                                <tr>
                                    <th class="px-6 py-4 cursor-pointer hover:bg-slate-100 transition" onclick="app.sortList('nome_segurado')">
                                        Segurado <i class="fa-solid fa-sort ml-1 text-slate-300"></i>
                                    </th>
                                    <th class="px-6 py-4">Ramo(s)</th>
                                    <th class="px-6 py-4 cursor-pointer hover:bg-slate-100 transition" onclick="app.sortList('etapa_nome')">
                                        Etapa <i class="fa-solid fa-sort ml-1 text-slate-300"></i>
                                    </th>
                                    <th class="px-6 py-4 text-center cursor-pointer hover:bg-slate-100 transition" onclick="app.sortList('retorno')">
                                        Data Retorno <i class="fa-solid fa-sort ml-1 text-slate-300"></i>
                                    </th>
                                    <th class="px-6 py-4 text-center cursor-pointer hover:bg-slate-100 transition" onclick="app.sortList('vigencia')">
                                        Vencimento <i class="fa-solid fa-sort ml-1 text-slate-300"></i>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="lista-tbody" class="divide-y divide-border text-sm">
                                </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="view-contatos" class="h-full overflow-y-auto p-8 hidden">
                <h2 class="text-3xl font-extrabold text-textMain mb-2">Base de Contatos</h2>
                <p class="text-textMuted mb-8">Acesse e gerencie o cadastro dos seus clientes.</p>
                
                <div class="bg-surface border border-border rounded-2xl shadow-sm overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-50 text-xs text-textMuted uppercase font-bold border-b border-border">
                            <tr>
                                <th class="px-6 py-4">Nome / Documento</th>
                                <th class="px-6 py-4">E-mail</th>
                                <th class="px-6 py-4">Telefone</th>
                                <th class="px-6 py-4">ChatWoot ID</th>
                                <th class="px-6 py-4">Status do Contato</th>
                            </tr>
                        </thead>
                        <tbody id="contatos-tbody" class="divide-y divide-border text-sm">
                            </tbody>
                    </table>
                </div>
            </div>

            <div id="view-segurados" class="h-full overflow-y-auto p-8 hidden">
                <h2 class="text-3xl font-extrabold text-textMain mb-2">Apólices Ativas (Segurados)</h2>
                <p class="text-textMuted mb-8">Listagem de todas as oportunidades fechadas com sucesso ("Ganho").</p>
                
                <div class="bg-surface border border-border rounded-2xl shadow-sm overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-emerald-50 text-xs text-emerald-800 uppercase font-bold border-b border-border">
                            <tr>
                                <th class="px-6 py-4">Nome do Segurado</th>
                                <th class="px-6 py-4">Ramo(s) do Seguro</th>
                                <th class="px-6 py-4 text-center">Data do Fechamento</th>
                                <th class="px-6 py-4 text-right">Receita Gerada</th>
                            </tr>
                        </thead>
                        <tbody id="segurados-tbody" class="divide-y divide-border text-sm">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="profileModal" class="fixed inset-0 bg-slate-900/60 hidden flex items-center justify-center z-[150] backdrop-blur-sm p-4">
        <div class="bg-surface rounded-2xl shadow-2xl w-[450px] overflow-hidden border border-border">
            <div class="px-6 py-4 border-b border-border flex justify-between items-center bg-slate-50">
                <h2 class="text-xl font-bold text-textMain">Meu Perfil</h2>
                <button type="button" onclick="ui.closeProfileModal()" class="text-textMuted hover:text-red-500 text-2xl outline-none">&times;</button>
            </div>
            
            <div class="p-6 space-y-5">
                <div class="flex flex-col items-center gap-3">
                    <div id="profile-modal-avatar" class="w-20 h-20 rounded-full bg-slate-200 border-4 border-white shadow-md flex items-center justify-center text-primary text-3xl bg-cover bg-center">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <input type="file" id="avatarUploadInput" accept="image/*" class="text-xs text-textMuted w-full max-w-[200px]">
