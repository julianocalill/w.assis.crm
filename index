            initApp: async () => {
                try {
                    try {
                        const {data: corrs} = await app.sb.from('corretores').select('*');
                        app.corretores = corrs || [];
                    } catch(e) {
                        app.corretores = [];
                    }

                    try {
                        const {data: conts} = await app.sb.from('contatos').select('*').order('nome');
                        app.contatos = conts || [];
                    } catch(e) {
                        app.contatos = [];
                    }

                    const gerenteSelect = document.getElementById('opGerente');
                    const filtroSelect = document.getElementById('filter-corretor');
                    let optionsHtml = '';
                    
                    app.corretores.forEach(c => {
                        let displayName = c.nome_completo || 'Corretor';
                        optionsHtml += `<option value="${c.id}">${displayName}</option>`;
                    });
                    
                    if (gerenteSelect) {
                        gerenteSelect.innerHTML += optionsHtml;
                    }
                    
                    // SPRINT 4: Identificando o Perfil do Usuário Logado
                    const perfil = app.corretores.find(c => c.id === app.user.id);
                    let userNameDisplay = 'Usuário';
                    let isGerente = false;

                    if (perfil) {
                        if (perfil.nome_completo) {
                            userNameDisplay = perfil.nome_completo;
                            document.getElementById('profileNome').value = perfil.nome_completo || '';
                        }
                        
                        // Checa se ele é gerente no banco
                        if (perfil.perfil === 'Gerente') {
                            isGerente = true;
                        }
                        
                        if (perfil.avatar_url) {
                            const bgUrl = `url('${perfil.avatar_url}')`;
                            document.getElementById('user-avatar').innerHTML = '';
                            document.getElementById('user-avatar').style.backgroundImage = bgUrl;
                            document.getElementById('profile-modal-avatar').innerHTML = '';
                            document.getElementById('profile-modal-avatar').style.backgroundImage = bgUrl;
                        }
                    } else if (app.user && app.user.email) {
                        try {
                            userNameDisplay = app.user.email.split('@')[0];
                        } catch(e) {}
                    }

                    const userNameEl = document.getElementById('user-name');
                    if (userNameEl) {
                        userNameEl.innerText = userNameDisplay;
                    }
                    
                    // Lógica de Trava (Se não for Gerente, bloqueia o select do filtro)
                    if (filtroSelect) {
                        filtroSelect.innerHTML += optionsHtml;
                        
                        const userNaLista = app.corretores.find(c => c.id === app.user.id);
                        if (userNaLista) {
                            filtroSelect.value = app.user.id;
                        }
                        
                        if (!isGerente) {
                            filtroSelect.disabled = true;
                            filtroSelect.classList.add('bg-slate-100', 'cursor-not-allowed', 'opacity-70');
                            document.getElementById('user-role').innerText = 'VENDEDOR';
                        } else {
                            document.getElementById('user-role').innerText = 'GERENTE';
                        }
