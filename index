        /**
         * Fechamento unificado: Esc e clique no backdrop (fora do card).
         * z-index alinhado às classes Tailwind dos overlays (deal 100, contato/fluxo 110, perfil/settings 150).
         */
        const overlayModals = {
            _flowDismiss: null,

            setFlowDismiss(fn) {
                this._flowDismiss = typeof fn === 'function' ? fn : null;
            },

            clearFlowDismiss() {
                this._flowDismiss = null;
            },

            _invokeFlowDismiss() {
                if (this._flowDismiss) {
                    this._flowDismiss();
                }
            },

            _defs() {
                const self = this;
                return [
                    { id: 'settingsModal', z: 150, close: () => ui.closeSettingsModal() },
                    { id: 'profileModal', z: 150, close: () => ui.closeProfileModal() },
                    { id: 'contatoModal', z: 110, close: () => ui.closeContatoModal() },
                    { id: 'modalReagendamento', z: 110, close: () => self._invokeFlowDismiss() },
                    { id: 'modalMotivoPerda', z: 110, close: () => self._invokeFlowDismiss() },
                    { id: 'modalEmailErp', z: 110, close: () => self._invokeFlowDismiss() },
                    { id: 'modalEmailProposta', z: 110, close: () => self._invokeFlowDismiss() },
                    { id: 'dealModal', z: 100, close: () => ui.closeDealModal() }
                ];
            },

            getTopOpen() {
                const open = [];
                for (const d of this._defs()) {
                    const el = document.getElementById(d.id);
                    if (!el || el.classList.contains('hidden')) {
                        continue;
                    }
                    open.push({ ...d, el });
                }
                if (!open.length) {
                    return null;
                }
                open.sort((a, b) => {
                    if (b.z !== a.z) {
                        return b.z - a.z;
                    }
                    const pos = a.el.compareDocumentPosition(b.el);
                    if (pos & Node.DOCUMENT_POSITION_FOLLOWING) {
                        return 1;
                    }
                    if (pos & Node.DOCUMENT_POSITION_PRECEDING) {
                        return -1;
                    }
                    return 0;
                });
                return open[0];
            },

            closeTop() {
                const top = this.getTopOpen();
                if (top) {
                    top.close();
                }
            },

            attachBackdropCloses() {
                for (const d of this._defs()) {
                    const el = document.getElementById(d.id);
                    if (!el || el.dataset.backdropCloseBound === '1') {
                        continue;
                    }
                    el.dataset.backdropCloseBound = '1';
                    el.addEventListener('mousedown', (e) => {
                        if (e.target !== el) {
                            return;
                        }
                        d.close();
                    });
                }
            },

            init() {
                this.attachBackdropCloses();
            }
        };

        const closeFlowModals = {
            show(id, vis) {
                const el = document.getElementById(id);
                if (el) {
                    el.classList.toggle('hidden', !vis);
                }
            },

            setupFileDrop(dropId, inputId) {
                const drop = document.getElementById(dropId);
                const inp = document.getElementById(inputId);
                if (!drop || !inp) {
                    return;
                }
                const labelHtml = 'Clique para escolher ou arraste os arquivos (Máx 5 arquivos)';
                drop.onclick = () => inp.click();
                drop.ondragover = (e) => { e.preventDefault(); drop.classList.add('bg-slate-100'); };
                drop.ondragleave = () => drop.classList.remove('bg-slate-100');
                drop.ondrop = (e) => {
                    e.preventDefault();
                    drop.classList.remove('bg-slate-100');
                    const files = Array.from(e.dataTransfer.files || []).slice(0, 5);
                    if (files.length) {
                        const dt = new DataTransfer();
                        files.forEach(f => dt.items.add(f));
                        inp.files = dt.files;
                        drop.innerHTML = `${files.length} arquivo(s) selecionado(s)`;
                    }
                };
                inp.onchange = () => {
                    const n = inp.files?.length || 0;
                    drop.innerHTML = n ? `${n} arquivo(s) selecionado(s)` : labelHtml;
                };
            },

            resetEmailModal(inpId, dropId) {
                const inp = document.getElementById(inpId);
                if (inp) {
                    inp.value = '';
                }
                const drop = document.getElementById(dropId);
                if (drop) {
                    drop.innerHTML = 'Clique para escolher ou arraste os arquivos (Máx 5 arquivos)';
                }
            },

            resetPropostaEmailUpload() {
                closeFlowModals.resetManagedEmailUpload('emailPropostaFiles', 'emailPropostaDrop', 'emailPropostaFileList', '_propostaFiles');
            },

            resetErpEmailUpload() {
                closeFlowModals.resetManagedEmailUpload('emailErpFiles', 'emailErpDrop', 'emailErpFileList', '_erpFiles');
            },

            resetManagedEmailUpload(inpId, dropId, listId, storeKey) {
                const inp = document.getElementById(inpId);
                const drop = document.getElementById(dropId);
                const listEl = document.getElementById(listId);
                const labelHtml = 'Clique para escolher ou arraste os arquivos (Máx 5 arquivos)';
                if (inp) {
                    inp.value = '';
                    inp[storeKey] = [];
                }
                if (listEl) {
                    listEl.innerHTML = '';
                }
                if (drop) {
                    drop.innerHTML = labelHtml;
                }
            },

            setupFileDropProposta() {
                closeFlowModals.setupManagedFileDrop({
                    dropId: 'emailPropostaDrop',
                    inputId: 'emailPropostaFiles',
                    listId: 'emailPropostaFileList',
                    storeKey: '_propostaFiles',
                    removeAttr: 'data-proposta-file-remove'
                });
            },

            setupFileDropErp() {
                closeFlowModals.setupManagedFileDrop({
                    dropId: 'emailErpDrop',
                    inputId: 'emailErpFiles',
                    listId: 'emailErpFileList',
                    storeKey: '_erpFiles',
                    removeAttr: 'data-erp-file-remove'
                });
            },

            setupManagedFileDrop({ dropId, inputId, listId, storeKey, removeAttr }) {
                const MAX = 5;
                const drop = document.getElementById(dropId);
                const inp = document.getElementById(inputId);
                const listEl = document.getElementById(listId);
                if (!drop || !inp || !listEl) {
                    return;
                }
                const labelHtml = 'Clique para escolher ou arraste os arquivos (Máx 5 arquivos)';
                const fileKey = (f) => `${f.name}|${f.size}|${f.lastModified}`;
                const escAttr = (s) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

                const getStore = () => {
                    if (!Array.isArray(inp[storeKey])) {
                        inp[storeKey] = [];
                    }
                    return inp[storeKey];
                };

                const syncInput = () => {
                    const store = getStore();
                    const dt = new DataTransfer();
                    store.forEach((f) => dt.items.add(f));
                    inp.files = dt.files;
                };

                const renderList = () => {
                    const store = getStore();
                    if (store.length === 0) {
                        listEl.innerHTML = '';
                        return;
                    }
                    listEl.innerHTML = store.map((f, i) => `
                        <div class="flex items-center justify-between gap-2 text-xs border border-border rounded-lg px-3 py-2 bg-slate-50">
                            <span class="truncate text-textMain font-medium" title="${escAttr(f.name)}">${escAttr(f.name)}</span>
                            <button type="button" class="shrink-0 text-red-600 hover:text-red-700 font-bold px-2 py-0.5 rounded border border-transparent hover:border-red-200" ${removeAttr}="${i}" aria-label="Remover anexo">Excluir</button>
                        </div>
                    `).join('');
                    listEl.querySelectorAll(`[${removeAttr}]`).forEach((btn) => {
                        btn.onclick = () => {
                            const idx = parseInt(btn.getAttribute(removeAttr), 10);
                            const st = getStore();
                            if (!Number.isNaN(idx) && idx >= 0 && idx < st.length) {
                                st.splice(idx, 1);
                                syncInput();
                                renderList();
                            }
                        };
                    });
                };

                const mergeIncoming = (rawList) => {
                    const store = getStore();
                    const existing = new Set(store.map(fileKey));
                    const novel = rawList.filter((f) => !existing.has(fileKey(f)));
                    const room = MAX - store.length;
                    if (novel.length > room) {
                        Swal.fire('Atenção', 'É permitido no máximo 5 anexos.', 'warning');
                    }
                    novel.slice(0, room).forEach((f) => store.push(f));
                    syncInput();
                    renderList();
                };

                drop.innerHTML = labelHtml;
                drop.onclick = () => inp.click();
                drop.ondragover = (e) => {
                    e.preventDefault();
                    drop.classList.add('bg-slate-100');
                };
                drop.ondragleave = () => drop.classList.remove('bg-slate-100');
                drop.ondrop = (e) => {
                    e.preventDefault();
                    drop.classList.remove('bg-slate-100');
                    const files = Array.from(e.dataTransfer.files || []);
                    if (files.length) {
                        mergeIncoming(files);
                    }
                };
                inp.onchange = () => {
                    const picked = Array.from(inp.files || []);
                    if (!picked.length) {
                        return;
                    }
                    mergeIncoming(picked);
                    inp.value = '';
                    syncInput();
                };
            },

            async filesToPayload(inpId) {
                const inp = document.getElementById(inpId);
                const files = Array.from(inp?.files || []).slice(0, 5);
                const out = [];
                for (const f of files) {
                    const entry = await new Promise((resolve, reject) => {
                        const fr = new FileReader();
                        fr.onload = () => {
                            const s = fr.result;
                            const i = s.indexOf(',');
                            resolve({ name: f.name, mime: f.type || 'application/octet-stream', base64: i >= 0 ? s.slice(i + 1) : s });
                        };
                        fr.onerror = () => reject(fr.error);
                        fr.readAsDataURL(f);
                    });
                    out.push(entry);
                }
                return out;
            },

            openEmailProposta() {
                return new Promise((resolve) => {
                    closeFlowModals.resetPropostaEmailUpload();
                    const m = 'modalEmailProposta';
                    const assunto = document.getElementById('emailPropostaAssunto');
                    const obs = document.getElementById('emailPropostaObs');
                    assunto.value = ui.buildPropostaAssuntoDefault();
                    obs.value = '';
                    const finish = (payload) => {
                        overlayModals.clearFlowDismiss();
                        document.getElementById('btnEmailPropostaCancel').onclick = null;
                        document.getElementById('btnEmailPropostaSend').onclick = null;
                        closeFlowModals.show(m, false);
                        resolve(payload);
                    };
                    overlayModals.setFlowDismiss(() => finish({ cancelled: true }));
                    document.getElementById('btnEmailPropostaCancel').onclick = () => finish({ cancelled: true });
                    document.getElementById('btnEmailPropostaSend').onclick = async () => {
                        const anexos = await closeFlowModals.filesToPayload('emailPropostaFiles');
                        finish({
                            cancelled: false,
                            email: { skipped: false, assunto: assunto.value.trim(), obs: obs.value.trim(), anexos }
                        });
                    };
                    closeFlowModals.show(m, true);
                });
            },

            openEmailErp() {
                return new Promise((resolve) => {
                    closeFlowModals.resetErpEmailUpload();
                    const m = 'modalEmailErp';
                    const assunto = document.getElementById('emailErpAssunto');
                    const obs = document.getElementById('emailErpObs');
                    assunto.value = ui.buildErpAssuntoDefault();
                    obs.value = '';
                    const finish = (payload) => {
                        overlayModals.clearFlowDismiss();
                        document.getElementById('btnEmailErpCancel').onclick = null;
                        document.getElementById('btnEmailErpSend').onclick = null;
                        closeFlowModals.show(m, false);
                        resolve(payload);
                    };
                    overlayModals.setFlowDismiss(() => finish({ cancelled: true }));
                    document.getElementById('btnEmailErpCancel').onclick = () => finish({ cancelled: true });
                    document.getElementById('btnEmailErpSend').onclick = async () => {
                        const anexos = await closeFlowModals.filesToPayload('emailErpFiles');
                        finish({
                            cancelled: false,
                            email: {
                                skipped: false,
                                assunto: assunto.value.trim(),
                                obs: obs.value.trim(),
                                anexos
                            }
                        });
                    };
                    closeFlowModals.show(m, true);
                });
            },

            openMotivoPerda() {
                return new Promise((resolve) => {
                    const sel = document.getElementById('motivoPerdaSelect');
                    const ta = document.getElementById('motivoPerdaText');
                    const opts = ['<option value="">Selecione um motivo...</option>']
                        .concat((app.motivosPerda || []).map(m => `<option value="${m.id}">${m.nome}</option>`));
                    sel.innerHTML = opts.join('');
                    sel.value = '';
                    ta.value = '';
                    const m = 'modalMotivoPerda';
                    const finish = (payload) => {
                        overlayModals.clearFlowDismiss();
                        document.getElementById('btnMotivoPerdaCancel').onclick = null;
                        document.getElementById('btnMotivoPerdaOk').onclick = null;
                        closeFlowModals.show(m, false);
                        resolve(payload);
                    };
                    overlayModals.setFlowDismiss(() => finish({ cancelled: true }));
                    document.getElementById('btnMotivoPerdaCancel').onclick = () => finish({ cancelled: true });
                    document.getElementById('btnMotivoPerdaOk').onclick = () => {
                        const selectedId = sel.value;
                        if (!selectedId) {
                            Swal.fire('Atenção', 'Selecione um motivo da perda para continuar.', 'warning');
                            return;
                        }
                        const motivoObj = (app.motivosPerda || []).find(motivo => String(motivo.id) === String(selectedId));
                        finish({
                            cancelled: false,
                            id: selectedId,
                            nome: motivoObj?.nome || 'Motivo não identificado',
                            observacao: ta.value.trim()
                        });
                    };
                    closeFlowModals.show(m, true);
                });
            },

            openReagendamento(motivoText, vigenciaBaseIso) {
                return new Promise((resolve) => {
                    const esc = (s) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
                    const toDateInputValue = (date) => {
                        const y = date.getFullYear();
                        const m = String(date.getMonth() + 1).padStart(2, '0');
                        const d = String(date.getDate()).padStart(2, '0');
                        return `${y}-${m}-${d}`;
                    };
                    const parseVigenciaBase = (raw) => {
                        if (raw == null || typeof raw !== 'string') return null;
                        const t = raw.trim().split('T')[0];
                        if (!t) return null;
                        const parts = t.split('-');
                        if (parts.length !== 3) return null;
                        const y = parseInt(parts[0], 10);
                        const mo = parseInt(parts[1], 10);
                        const da = parseInt(parts[2], 10);
                        if (Number.isNaN(y) || Number.isNaN(mo) || Number.isNaN(da)) return null;
                        const dt = new Date(y, mo - 1, da);
                        if (dt.getFullYear() !== y || dt.getMonth() !== mo - 1 || dt.getDate() !== da) return null;
                        return dt;
                    };
                    let html = ui.buildReagendamentoResumoHtml();
                    if (motivoText) {
                        html += `<div class="mt-3 pt-3 border-t border-border"><p class="leading-relaxed"><strong>Motivo:</strong> ${esc(motivoText)}</p></div>`;
                    }
                    document.getElementById('reagResumoHtml').innerHTML = html;
                    const baseDate = parseVigenciaBase(String(vigenciaBaseIso || '')) || new Date();
                    const vigenciaDefaultDate = new Date(baseDate);
                    vigenciaDefaultDate.setFullYear(vigenciaDefaultDate.getFullYear() + 1);
                    const retornoDefaultDate = new Date(vigenciaDefaultDate);
                    retornoDefaultDate.setDate(retornoDefaultDate.getDate() - 15);
                    document.getElementById('reagVigencia').value = toDateInputValue(vigenciaDefaultDate);
                    document.getElementById('reagRetorno').value = toDateInputValue(retornoDefaultDate);
                    const m = 'modalReagendamento';
                    const finish = (payload) => {
                        overlayModals.clearFlowDismiss();
                        document.getElementById('btnReagNaoCriar').onclick = null;
                        document.getElementById('btnReagCriar').onclick = null;
                        closeFlowModals.show(m, false);
                        resolve(payload);
                    };
                    overlayModals.setFlowDismiss(() => finish({ criar: false }));
                    document.getElementById('btnReagNaoCriar').onclick = () => finish({ criar: false });
                    document.getElementById('btnReagCriar').onclick = () => finish({
                        criar: true,
                        vigencia: document.getElementById('reagVigencia').value || null,
                        retorno: document.getElementById('reagRetorno').value || null
                    });
                    closeFlowModals.show(m, true);
                });
            }
        };

        // Inicia o app quando o DOM estiver pronto
        document.addEventListener('DOMContentLoaded', () => {
            if (window.Swal && typeof Swal.mixin === 'function') {
                Swal.mixin({ allowEscapeKey: true, allowOutsideClick: true });
            }

            closeFlowModals.setupFileDropProposta();
            closeFlowModals.setupFileDropErp();

            overlayModals.init();

            ui.initSidebar();
            ui.initOportunidadesFiltros();
            app.init();

            document.addEventListener('keydown', (e) => {
                if (e.key !== 'Escape') {
                    return;
                }
                const top = overlayModals.getTopOpen();
                if (top) {
                    top.close();
                    e.preventDefault();
                }
            });
        });
    </script>
