                    return;
                }

                if (meta.totalItems === 0) {
                    infoEl.innerText = 'Mostrando 0 de 0 contatos';
                    pageEl.innerText = 'Página 0 de 0';
                    prevBtn.disabled = true;
                    nextBtn.disabled = true;
                    return;
                }

                const startHuman = meta.start + 1;
                const endHuman = Math.min(meta.end, meta.totalItems);
                infoEl.innerText = `Mostrando ${startHuman}-${endHuman} de ${meta.totalItems} contatos`;
                pageEl.innerText = `Página ${meta.currentPage} de ${meta.totalPages}`;
