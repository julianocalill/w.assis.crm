                };
                Object.values(map).forEach((id) => {
                    const el = document.getElementById(id);
                    if (el) {
                        el.className = 'fa-solid fa-sort ml-1 text-slate-300';
                    }
                });
                const activeId = map[app.historicoOpsSortKey];
                const active = activeId ? document.getElementById(activeId) : null;
                if (active) {
                    active.className = `fa-solid ${app.historicoOpsSortAsc ? 'fa-sort-up' : 'fa-sort-down'} ml-1 text-primary`;
