            renderBoard: (etapas) => {
                const board = document.getElementById('board-kanban');
                const collapsedStages = new Set();
                board.querySelectorAll('.kanban-col.collapsed .kanban-list').forEach((list) => {
                    if (list.dataset.stage) {
                        collapsedStages.add(list.dataset.stage);
                    }
                });
                board.innerHTML = '';
                
                const sel = document.getElementById('opEtapaHeader');
                sel.innerHTML = etapas.map(e => `<option value="${e.nome}">${e.nome}</option>`).join('');

                etapas.forEach((e) => {
                    const col = ui.buildColumnHTML(e.nome, e.cor, 'deals');
                    if (collapsedStages.has(e.nome)) {
                        col.classList.add('collapsed');
                    }
                    board.appendChild(col);
                });

                board.querySelectorAll('.kanban-list').forEach(list => {
                    new Sortable(list, { 
                        group: 'deals', 
                        animation: 150, 
                        ghostClass: 'ghost-card',
                        onEnd: (evt) => { 
                            if (evt.to.dataset.stage !== evt.from.dataset.stage) { 
                                window.app.moveDeal(evt.item.dataset.id, evt.to.dataset.stage, evt.from.dataset.stage); 
                            } 
                        } 
                    });
                });
            },

