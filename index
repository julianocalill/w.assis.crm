                }

                tbody.innerHTML = listaOps.map(d => {
                    const ramosText = ui.oportunidadeRamoExibicao(d);

                    let bgRowClass = 'hover:bg-slate-50 border-b border-border';
                    let textRetornoClass = 'text-textMuted font-medium';
                    
                    if (d.retorno && d.status === 'aberto' && !d.excluido) {
                        const hoje = new Date(); hoje.setHours(0,0,0,0);
                        const [ano, mes, dia] = d.retorno.split('-');
                        const dataRet = new Date(ano, mes - 1, dia); dataRet.setHours(0,0,0,0);
                        
                        if (dataRet < hoje) {
                            bgRowClass = 'bg-red-50/50 hover:bg-red-50 border-b border-red-100';
                            textRetornoClass = 'text-red-600 font-bold';
