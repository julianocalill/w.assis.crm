            saveIntegrations: async () => {
                if (!app.isGerente) {
                    return Swal.fire('Acesso negado', 'Somente gerente pode alterar integrações.', 'warning');
                }

                const token = document.getElementById('configCwToken').value.trim();
                const n8nGanho = document.getElementById('configN8nGanho').value.trim();
                const n8nUser = document.getElementById('configN8nUser').value.trim();

                const now = new Date().toISOString();
                const rows = [
                    { key: 'n8n_deal_webhook', value: n8nGanho, descricao: 'Webhook fixo para negócio ganho / pós-venda', atualizado_em: now },
                    { key: 'n8n_user_webhook', value: n8nUser, descricao: 'Webhook fixo para criação de novo usuário', atualizado_em: now }
                ];
                if (token) {
                    rows.unshift({ key: 'chatwoot', value: token, descricao: null, atualizado_em: now });
                }

                try {
                    const { error } = await app.sb.from('app_config').upsert(rows, { onConflict: 'key' });
                    if (error) {
                        throw error;
                    }
                    rows.forEach(r => { app.appConfig[r.key] = r.value; });
                    const cwTokInp = document.getElementById('configCwToken');
                    const cwTokStatus = document.getElementById('configCwTokenStatus');
                    if (cwTokInp) cwTokInp.value = '';
                    if (cwTokStatus) {
                        const hasTok = !!(app.appConfig && String(app.appConfig.chatwoot || '').trim());
                        cwTokStatus.textContent = hasTok
                            ? 'Token já está salvo no Supabase. O valor não é exibido. Digite abaixo apenas para substituir.'
                            : 'Nenhum token salvo. Cole o token gerado no painel do Chatwoot.';
                    }
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Integrações salvas no Supabase!', showConfirmButton: false, timer: 2000 });
                } catch (e) {
                    console.error(e);
                    Swal.fire('Erro', (e && e.message) ? e.message : 'Falha ao salvar app_config.', 'error');
                }
            },

            loadAppConfig: async () => {
                app.appConfig = {};
                try {
                    const { data, error } = await app.sb.from('app_config').select('key, value');
                    if (error) {
