            uploadArquivo: async () => {
                const fileInput = document.getElementById('fileUploadInput'); 
                const opId = document.getElementById('opId').value;
                
                if (!fileInput.files || fileInput.files.length === 0) {
                    return Swal.fire('Aviso', 'Selecione um arquivo primeiro.', 'warning');
                }
                
                if (!opId) {
                    return Swal.fire('Erro', 'Oportunidade inválida.', 'error');
                }

                const file = fileInput.files[0]; 
                const fileExt = file.name.split('.').pop();
                const fileName = `${opId}/${Date.now()}.${fileExt}`; 
                
                const areaUpload = document.getElementById('arquivos-area-upload');
                const htmlOriginal = areaUpload.innerHTML;
                
                areaUpload.innerHTML = '<div class="text-center py-10 bg-slate-50 rounded-xl border-2 border-dashed border-primary"><i class="fa-solid fa-spinner fa-spin text-4xl text-primary mb-3"></i><p class="font-bold text-lg text-primary">Fazendo upload na nuvem...</p></div>';

                try {
                    const { data: uploadData, error: uploadError } = await app.sb.storage.from('arquivos_crm').upload(fileName, file);
                    if (uploadError) {
                        throw uploadError;
                    }

                    const { data: publicUrlData } = app.sb.storage.from('arquivos_crm').getPublicUrl(fileName);
                    
                    const anexoData = {
                        oportunidade_id: opId,
                        nome_arquivo: file.name,
                        url_arquivo: publicUrlData.publicUrl,
                        tamanho_bytes: file.size,
                        criado_por: app.user.id
                    };
                    
                    const { error: dbError } = await app.sb.from('anexos').insert([anexoData]);
                    if (dbError) {
                        throw dbError;
                    }

                    app.logTimeline(opId, 'Arquivo Anexado', `O documento ${file.name} foi adicionado à pasta digital.`);
                    Swal.fire({toast: true, position: 'top-end', icon: 'success', title: 'Sucesso!', showConfirmButton: false, timer: 1500});
                } catch (e) {
                    Swal.fire('Erro ao Enviar', e.message, 'error');
                } finally {
                    areaUpload.innerHTML = htmlOriginal;
                    app.loadArquivos(opId);
                    app.loadTimeline(opId);
                }
            },

