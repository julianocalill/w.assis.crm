            onBuscaContatoModalInput: (role, termo) => {
                const timeoutKey = role === 'responsavel' ? 'responsavelBuscaTimeout' : 'contatoBuscaTimeout';
                if (app[timeoutKey]) {
                    clearTimeout(app[timeoutKey]);
                }

                app[timeoutKey] = setTimeout(() => {
                    const resultados = app.buscarContatosNoModal(termo);
                    app.renderBuscaContatosModal(role, resultados, termo);
                }, 300);
            },

            buscarContatosNoModal: (termo) => {
                const qText = app.normalizeText(termo);
                const qDigits = app.normalizeDigits(termo);

                if (!qText && !qDigits) return [];
                if (!qDigits && qText.length < 2) return [];

                const matches = [];
                app.contatos.forEach(c => {
                    const nome = app.normalizeText(c.nome);
                    const doc = app.normalizeDigits(c.documento);
                    const tel = app.normalizeDigits(c.telefone);
                    let score = 0;

                    if (qDigits && (qDigits.length === 11 || qDigits.length === 14) && doc === qDigits) {
                        score = 100;
                    } else if (qDigits && tel && (tel === qDigits || tel.startsWith(qDigits))) {
                        score = 90;
                    } else if (qText && nome.includes(qText)) {
                        score = 80;
                    } else if (qDigits && ((doc && doc.includes(qDigits)) || (tel && tel.includes(qDigits)))) {
                        score = 70;
                    }

                    if (score > 0) {
                        matches.push({ contato: c, score });
                    }
                });

                return matches
                    .sort((a, b) => b.score - a.score || ((a.contato.nome || '').localeCompare(b.contato.nome || '', 'pt-BR')))
                    .slice(0, 8)
                    .map(m => m.contato);
            },

            renderBuscaContatosModal: (role, resultados, termo) => {
                const f = MODAL_CONTATO_FIELDS[role];
                if (!f) return;
                const box = document.getElementById(f.resultados);
                const status = document.getElementById(f.status);
                if (!box || !status) return;

                const query = (termo || '').trim();
                if (!query) {
                    box.classList.add('hidden');
                    box.innerHTML = '';
                    status.innerText = '';
                    return;
                }

                if (!resultados || resultados.length === 0) {
                    const safeQuery = app.escapeHtml(query);
                    box.innerHTML = `
                        <div class="px-4 py-3 text-sm text-textMuted">Nenhum cliente encontrado para "<span class="font-semibold text-textMain">${safeQuery}</span>".</div>
                        <button type="button" onclick="app.usarCadastroNovoModal('${role}')" class="w-full text-left px-4 py-3 border-t border-border text-primary hover:bg-blue-50 transition text-sm font-semibold">
                            <i class="fa-solid fa-user-plus mr-2"></i>Cadastrar novo cliente com os dados digitados
                        </button>
                    `;
                    box.classList.remove('hidden');
                    status.innerText = 'Nenhum cliente localizado. Preencha os campos para novo cadastro.';
                    return;
                }

                box.innerHTML = resultados.map(c => {
                    const nome = app.escapeHtml(c.nome || 'Sem nome');
                    const doc = c.documento ? ui.maskDoc(c.documento) : '-';
                    const tel = c.telefone ? ui.maskPhone(c.telefone) : '-';
                    return `
                        <button type="button" onclick="app.selecionarContatoModal('${role}', ${c.id})" class="w-full text-left px-4 py-3 border-b border-slate-100 hover:bg-slate-50 transition">
                            <div class="text-sm font-semibold text-textMain">${nome}</div>
                            <div class="text-xs text-textMuted mt-0.5 font-mono">${doc} | ${tel}</div>
                        </button>
                    `;
                }).join('');

                box.classList.remove('hidden');
                status.innerText = `${resultados.length} cliente(s) encontrado(s).`;
            },

