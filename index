            saveDeal: async (e) => {
                e.preventDefault(); 
                const btnSubmit = e.target.querySelector('button[type="submit"]');
                const originalBtnText = btnSubmit.innerHTML;
                
                btnSubmit.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...';
                btnSubmit.disabled = true;

                const opId = document.getElementById('opId').value;
                if (opId) {
                    const opBloqueio = app.oportunidades.find(o => o.id == opId);
                    if (opBloqueio && !app.isGerente && (opBloqueio.status === 'ganho' || opBloqueio.status === 'perdido' || opBloqueio.excluido)) {
                        Swal.fire('Somente leitura', 'Negócios fechados, excluídos ou na lixeira só podem ser alterados por um gerente.', 'info');
                        btnSubmit.innerHTML = originalBtnText;
                        btnSubmit.disabled = false;
                        return;
                    }
                }
                let contatoId = document.getElementById('contatoId').value;
                const mesmoResp = document.getElementById('opResponsavelMesmo').checked;
                let responsavelId = document.getElementById('responsavelId').value;

                if (!mesmoResp) {
                    const nomeResp = document.getElementById('opRespNome').value.trim();
                    if (!nomeResp) {
                        Swal.fire('Atenção', 'Informe o nome do responsável pela negociação ou marque que é o mesmo que o segurado.', 'warning');
                        btnSubmit.innerHTML = originalBtnText;
                        btnSubmit.disabled = false;
                        return;
                    }
                } else {
                    responsavelId = '';
                }

                const contatoData = { 
                    nome: document.getElementById('opNome').value, 
                    documento: document.getElementById('opDocumento').value, 
                    email: document.getElementById('opEmail').value, 
                    telefone: document.getElementById('opTelefone').value,
                    chatwoot_id: document.getElementById('opChatwootId').value,
                    corretor_id: app.user.id 
                };

                const idsExcluirSeg = [contatoId, (!mesmoResp ? responsavelId : '')].filter(Boolean);
                const docRaw = contatoData.documento.replace(/\D/g, '');
                if (docRaw) {
                    const docExiste = app.contatos.find(c => c.documento && c.documento.replace(/\D/g, '') === docRaw && !idsExcluirSeg.some(id => c.id == id));
                    if (docExiste) {
                        Swal.fire('Atenção', 'Já existe um cliente cadastrado com este CPF/CNPJ: ' + docExiste.nome, 'warning');
                        btnSubmit.innerHTML = originalBtnText;
                        btnSubmit.disabled = false;
                        return;
                    }
                }
                
                const telRawSeg = contatoData.telefone.replace(/\D/g, '');
                if (telRawSeg) {
                    const telExiste = app.contatos.find(c => c.telefone && c.telefone.replace(/\D/g, '') === telRawSeg && !idsExcluirSeg.some(id => c.id == id));
                    if (telExiste) {
                        Swal.fire('Atenção', 'Já existe um cliente cadastrado com este telefone: ' + telExiste.nome, 'warning');
                        btnSubmit.innerHTML = originalBtnText;
                        btnSubmit.disabled = false;
                        return;
                    }
                }

                const respData = !mesmoResp ? {
                    nome: document.getElementById('opRespNome').value, 
                    documento: document.getElementById('opRespDocumento').value, 
                    email: document.getElementById('opRespEmail').value, 
                    telefone: document.getElementById('opRespTelefone').value,
                    chatwoot_id: document.getElementById('opRespChatwootId').value,
                    corretor_id: app.user.id 
                } : null;

                if (respData) {
                    const idsExcluirResp = [contatoId, responsavelId].filter(Boolean);
                    const docR = respData.documento.replace(/\D/g, '');
                    if (docR) {
                        const docExiste = app.contatos.find(c => c.documento && c.documento.replace(/\D/g, '') === docR && !idsExcluirResp.some(id => c.id == id));
                        if (docExiste) {
                            Swal.fire('Atenção', 'Responsável: já existe um cliente com este CPF/CNPJ: ' + docExiste.nome, 'warning');
                            btnSubmit.innerHTML = originalBtnText;
                            btnSubmit.disabled = false;
                            return;
                        }
                    }
                    const telR = respData.telefone.replace(/\D/g, '');
                    if (telR) {
                        const telExiste = app.contatos.find(c => c.telefone && c.telefone.replace(/\D/g, '') === telR && !idsExcluirResp.some(id => c.id == id));
                        if (telExiste) {
                            Swal.fire('Atenção', 'Responsável: já existe um cliente com este telefone: ' + telExiste.nome, 'warning');
                            btnSubmit.innerHTML = originalBtnText;
                            btnSubmit.disabled = false;
                            return;
                        }
                    }
                }

                try {
                    if (!contatoId) {
                        const {data: newContato, error: errC} = await app.sb.from('contatos').insert([contatoData]).select();
                        if (errC) {
                            throw errC;
                        }
                        contatoId = newContato[0].id;
                        app.contatos.push(newContato[0]);
                        ui.renderContatosTable();
                    } else { 
                        await app.sb.from('contatos').update(contatoData).eq('id', contatoId); 
                        const ctIndex = app.contatos.findIndex(c => c.id == contatoId);
                        if (ctIndex >= 0) {
                            app.contatos[ctIndex] = {...app.contatos[ctIndex], ...contatoData};
                        }
                        ui.renderContatosTable();
                    }

                    let responsavelIdFinal = null;
                    if (!mesmoResp && respData) {
                        let rid = responsavelId;
                        if (!rid) {
                            const {data: newR, error: errR} = await app.sb.from('contatos').insert([respData]).select();
                            if (errR) {
                                throw errR;
                            }
                            rid = newR[0].id;
                            app.contatos.push(newR[0]);
                            ui.renderContatosTable();
                        } else {
                            await app.sb.from('contatos').update(respData).eq('id', rid);
                            const ri = app.contatos.findIndex(c => c.id == rid);
                            if (ri >= 0) {
                                app.contatos[ri] = {...app.contatos[ri], ...respData};
                            }
                            ui.renderContatosTable();
                        }
                        responsavelIdFinal = rid;
                    }

                    const defaultRamoSave = app.ramos.length > 0 ? app.ramos[0].nome : 'Automóvel';
                    const p0 = (ui.produtos && ui.produtos[0]) ? ui.produtos[0] : {};
                    const premioLiq = parseFloat(p0.premio) || 0;
                    const comissPct = parseFloat(p0.comissao) || 0;
                    const agencPct = parseFloat(p0.agenciamento) || 0;
                    
