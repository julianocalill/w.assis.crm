                    }
                    (data || []).forEach(r => { app.appConfig[r.key] = r.value; });
                    ['nexus_cw_url', 'nexus_cw_account', 'nexus_cw_token', 'nexus_n8n_ganho', 'nexus_n8n_user'].forEach(k => localStorage.removeItem(k));
