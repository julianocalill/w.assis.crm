                }
                
                ['dashboard', 'segurados', 'oportunidades', 'contatos'].forEach(v => {
                    const el = document.getElementById(`view-${v}`);
                    if (el) {
                        el.classList.add('hidden');
                    }
                });
                
                const elView = document.getElementById(`view-${view}`);
                if (elView) {
                    elView.classList.remove('hidden');
                }
                
                if (view === 'dashboard') {
                    (async () => {
                        await app.loadMetricsOpsSnapshot();
                        app.updateDashboard();
                    })();
                }
            },

            loadPipelines: async () => {
                try {
                    const {data} = await app.sb.from('funis').select('*').order('id');
                    app.funis = data || [];
                    
                    if (!config.activePipeline && app.funis.length > 0) {
                        config.activePipeline = app.funis[0].id;
                        try {
                            localStorage.setItem('nexus_active_pipe', String(config.activePipeline));
                        } catch (e) {
                            /* ignore */
                        }
                    }
                    
                    const html = app.funis.map(p => {
                        const isSelected = p.id == config.activePipeline ? 'selected' : '';
                        return `<option value="${p.id}" ${isSelected}>${p.nome}</option>`;
                    }).join('');
                    
                    const sel1 = document.getElementById('pipeline-selector');
                    const sel2 = document.getElementById('analytics-pipeline-selector');
                    
                    if (sel1) {
                        sel1.innerHTML = html; 
                    }
                    if (sel2) {
                        sel2.innerHTML = html;
                    }
                } catch(e) {
                    console.error("Erro Funis:", e);
                }
            },

            switchPipeline: async (id) => { 
                config.activePipeline = id;
                try {
                    localStorage.setItem('nexus_active_pipe', String(id));
                } catch (e) {
                    /* ignore */
                }
                app.loadPipelines(); 
                await app.loadData(); 
            },

            loadContatos: async () => {
                try {
                    app.contatos = await app.loadAllContatos();
                    ui.renderContatosTable();
                } catch (e) {
                    console.error("Erro ao carregar contatos:", e);
                }
            },

            /** Evita segundo redesenho quando o Realtime ecoa uma alteração feita nesta aba (debounce + tempo de loadData). */
            suppressRealtimeBoardSync: (ms) => {
                const deb = app._realtimeBoardDebounceMs ?? 400;
                const delta = ms !== undefined && ms !== null ? ms : deb + 1000;
                const until = Date.now() + delta;
                const prev = app._suppressRealtimeBoardSyncUntil || 0;
                app._suppressRealtimeBoardSyncUntil = Math.max(prev, until);
            },

            enrichOp: (op) => {
                const ct = app.contatos.find(c => c.id === op.contato_id);
                if (ct) {
                    op.nome_contato = ct.nome;
                    op.documento_contato = ct.documento;
                    op.chatwoot_id = ct.chatwoot_id;
                    op.email_contato = ct.email;          
                    op.telefone_contato = ct.telefone;    
                }

                const respCt = op.responsavel_id ? app.contatos.find(c => c.id === op.responsavel_id) : null;
                if (respCt) {
                    op.nome_responsavel = respCt.nome;
                    op.documento_responsavel = respCt.documento;
                    op.telefone_responsavel = respCt.telefone;
                    op.email_responsavel = respCt.email;
                    op.chatwoot_responsavel = respCt.chatwoot_id;
                }
                
                const cor = app.corretores.find(c => c.id === op.corretor_id);
                if (cor) {
                    op.nome_corretor = cor.nome_completo;
                    op.avatar_corretor = cor.avatar_url || null;
                } else {
                    op.avatar_corretor = null;
                }
                return op;
            },

            applyOpFilters: (o) => {
                if (String(o.funil_id) !== String(config.activePipeline)) {
                    return false;
                }
                const fOpId = (document.getElementById('filter-oportunidade-id')?.value || '').trim();
                if (fOpId) {
                    const pid = parseInt(fOpId, 10);
                    if (!Number.isFinite(pid) || String(o.id) !== String(pid)) {
                        return false;
                    }
                }
                const fStatus = document.getElementById('filter-status')?.value;
                if (fStatus === 'excluido') {
                    if (!o.excluido) return false;
                } else {
                    if (o.excluido) return false;
                    if (fStatus && fStatus !== 'excluido' && (o.status || 'aberto') !== fStatus) {
                        return false;
                    }
                }

                if (!app.isGerente && app.user && app.user.id) {
                    if (o.corretor_id !== app.user.id) return false;
                }

                const fDataIni = document.getElementById('filter-data-ini')?.value;
                const fDataFim = document.getElementById('filter-data-fim')?.value;
                const fDataCampo = document.getElementById('filter-data-campo')?.value || 'vigencia';
                if (fDataIni || fDataFim) {
                    const raw = o[fDataCampo];
                    if (!raw) return false;
                    const d = String(raw).slice(0, 10);
                    if (fDataIni && d < fDataIni) return false;
                    if (fDataFim && d > fDataFim) return false;
                }

                const fEtapa = document.getElementById('filter-etapa')?.value;
                if (fEtapa && o.etapa_nome !== fEtapa) return false;

                const fSeguradora = document.getElementById('filter-seguradora')?.value;
                if (fSeguradora && (o.seguradora || '') !== fSeguradora) return false;

                const fNomeCliente = (document.getElementById('filter-nome-cliente')?.value || '').trim().toLowerCase();
                if (fNomeCliente) {
                    const hay = `${ui.nomeSeguradoExibicao(o)} ${o.nome_oportunidade || ''}`.toLowerCase();
                    if (!hay.includes(fNomeCliente)) return false;
                }

                const fOrigem = document.getElementById('filter-origem')?.value;
                if (fOrigem && o.origem !== fOrigem) return false;

                const fCorretor = document.getElementById('filter-corretor')?.value;
                if (fCorretor && o.corretor_id !== fCorretor) return false;

                const fConf = document.getElementById('filter-conferencia')?.value;
                if (fConf === 'nao' && o.is_checked) return false;
                if (fConf === 'sim' && o.is_checked !== true) return false;

                const fRamo = document.getElementById('filter-ramo')?.value;
                if (fRamo) {
                    const matchRamo = o.ramo_seguro === fRamo || (o.produtos && Array.isArray(o.produtos) && o.produtos.some(p => p.ramo === fRamo));
                    if (!matchRamo) return false;
                }

                return true;
            },

            mergeOportunidadeIntoCache: (op) => {
                if (!op || op.id == null) return;
                const idx = app.oportunidades.findIndex(o => String(o.id) === String(op.id));
                if (idx >= 0) {
                    app.oportunidades[idx] = { ...app.oportunidades[idx], ...op };
                } else {
                    app.oportunidades.push(op);
                }
            },

            isKanbanCardMode: () => {
                const fStatus = document.getElementById('filter-status')?.value || '';
                return fStatus !== 'excluido' && fStatus !== 'ganho' && fStatus !== 'perdido';
            },

            shouldSkipKanbanColumn: (stageName) => {
                if (!app.isKanbanCardMode()) {
                    return true;
                }
                const fEtapa = document.getElementById('filter-etapa')?.value;
                if (fEtapa && fEtapa !== stageName) {
                    return true;
                }
                return false;
            },

            setKanbanBadge: (stageName, n) => {
                const col = document.querySelector(`.kanban-list[data-stage="${CSS.escape(stageName)}"]`)?.closest('.kanban-col');
                if (!col) return;
                const bubbleFull = col.querySelector('.count');
                const bubbleCollapsed = col.querySelector('.count-collapsed');
                const txt = String(n);
                if (bubbleFull) bubbleFull.innerText = txt;
                if (bubbleCollapsed) bubbleCollapsed.innerText = txt;
            },

            applyOportunidadesDbFilters: (q, opts = {}) => {
                const mode = opts.mode || 'lista';
                const etapaNome = opts.etapaNome;

                if ((mode === 'kanbanCount' || mode === 'kanbanPage') && !app.isKanbanCardMode()) {
                    return null;
                }

                q = q.eq('funil_id', config.activePipeline);

                const fStatus = document.getElementById('filter-status')?.value;
                if (fStatus === 'excluido') {
                    q = q.eq('excluido', true);
                } else {
                    q = q.eq('excluido', false);
                    if (fStatus && fStatus !== 'excluido') {
                        q = q.eq('status', fStatus);
                    }
                }

                if (mode === 'kanbanCount' || mode === 'kanbanPage') {
                    q = q.eq('status', 'aberto');
                    if (etapaNome) {
                        q = q.eq('etapa_nome', etapaNome);
                    }
                    const fEtapa = document.getElementById('filter-etapa')?.value;
                    if (fEtapa && fEtapa !== etapaNome) {
                        return null;
                    }
                } else {
                    const fEtapa = document.getElementById('filter-etapa')?.value;
                    if (fEtapa) {
                        q = q.eq('etapa_nome', fEtapa);
                    }
                }

                if (!app.isGerente && app.user && app.user.id) {
                    q = q.eq('corretor_id', app.user.id);
                }

                const opIdRaw = (document.getElementById('filter-oportunidade-id')?.value || '').trim();
                if (opIdRaw) {
                    const pid = parseInt(opIdRaw, 10);
                    if (Number.isFinite(pid)) {
                        q = q.eq('id', pid);
                    } else {
                        return null;
                    }
                }

                const fDataIni = document.getElementById('filter-data-ini')?.value;
                const fDataFim = document.getElementById('filter-data-fim')?.value;
                const fDataCampo = document.getElementById('filter-data-campo')?.value || 'vigencia';
                if (fDataIni) {
                    q = q.gte(fDataCampo, fDataIni);
                }
                if (fDataFim) {
                    q = q.lte(fDataCampo, fDataFim);
                }

                const fSeguradora = document.getElementById('filter-seguradora')?.value;
                if (fSeguradora) {
                    q = q.eq('seguradora', fSeguradora);
                }

                const fOrigem = document.getElementById('filter-origem')?.value;
                if (fOrigem) {
                    q = q.eq('origem', fOrigem);
                }

                const fCorretor = document.getElementById('filter-corretor')?.value;
                if (fCorretor) {
                    q = q.eq('corretor_id', fCorretor);
                }

                const fConf = document.getElementById('filter-conferencia')?.value;
                if (fConf === 'nao') {
                    q = q.eq('is_checked', false);
                }
                if (fConf === 'sim') {
                    q = q.eq('is_checked', true);
                }

                const fRamo = document.getElementById('filter-ramo')?.value;
                if (fRamo) {
                    q = q.eq('ramo_seguro', fRamo);
                }

                return q;
            },

            teardownKanbanScrollListeners: () => {
                (app._kanbanScrollHandlers || []).forEach(({ list, onScroll }) => {
                    list.removeEventListener('scroll', onScroll);
                });
                app._kanbanScrollHandlers = [];
                Object.keys(app._kanbanScrollTimers || {}).forEach((k) => {
                    clearTimeout(app._kanbanScrollTimers[k]);
                });
                app._kanbanScrollTimers = {};
            },

            attachKanbanColumnScrollListeners: () => {
                app.teardownKanbanScrollListeners();
                document.querySelectorAll('.kanban-list').forEach((list) => {
                    const stage = list.dataset.stage;
                    if (!stage) return;
                    const onScroll = () => {
                        if (app._kanbanScrollTimers[stage]) {
                            clearTimeout(app._kanbanScrollTimers[stage]);
                        }
                        app._kanbanScrollTimers[stage] = setTimeout(() => {
                            const nearBottom = list.scrollTop + list.clientHeight >= list.scrollHeight - 120;
                            if (nearBottom) {
                                app.loadKanbanColumnPage(stage, false);
                            }
                        }, 120);
                    };
                    list.addEventListener('scroll', onScroll, { passive: true });
                    app._kanbanScrollHandlers.push({ list, onScroll });
                });
            },

            refreshKanbanColumnCounts: async () => {
                if (!app.etapas || !app.etapas.length) {
                    return;
                }
                await Promise.all(app.etapas.map(async (e) => {
                    const stage = e.nome;
                    if (app.shouldSkipKanbanColumn(stage)) {
                        app.kanbanColState[stage] = { offset: 0, loading: false, hasMore: false, serverTotal: 0 };
                        app.setKanbanBadge(stage, 0);
                        return;
                    }
                    let q = app.sb.from('oportunidades').select('*', { count: 'exact', head: true });
                    q = app.applyOportunidadesDbFilters(q, { mode: 'kanbanCount', etapaNome: stage });
                    if (!q) {
                        app.kanbanColState[stage] = { offset: 0, loading: false, hasMore: false, serverTotal: 0 };
                        app.setKanbanBadge(stage, 0);
                        return;
                    }
                    const { count, error } = await q;
                    if (error) {
                        console.error('Erro count kanban', stage, error);
                    }
                    const total = count || 0;
                    app.kanbanColState[stage] = {
                        offset: 0,
                        loading: false,
                        hasMore: total > 0,
                        serverTotal: total
                    };
                    app.setKanbanBadge(stage, total);
                }));
                app.refreshHeaderPendenteFromServerTotals();
            },

            refreshHeaderPendenteFromServerTotals: () => {
                let sum = 0;
                Object.keys(app.kanbanColState || {}).forEach((k) => {
                    sum += app.kanbanColState[k].serverTotal || 0;
                });
                const headerLeads = document.getElementById('header-total-leads');
                if (headerLeads) {
                    headerLeads.innerText = `${sum} pendentes`;
                }
            },

            adjustKanbanColumnTotal: (stageName, delta) => {
                if (!stageName || !delta) {
                    return;
                }
                const st = app.kanbanColState[stageName];
                if (!st) {
                    return;
                }
                st.serverTotal = Math.max(0, (st.serverTotal || 0) + delta);
                app.setKanbanBadge(stageName, st.serverTotal);
                app.refreshHeaderPendenteFromServerTotals();
            },

            scheduleKanbanCountsDebounced: () => {
                if (app._debounceKanbanCounts) {
                    clearTimeout(app._debounceKanbanCounts);
                }
                app._debounceKanbanCounts = setTimeout(async () => {
                    app._debounceKanbanCounts = null;
                    try {
                        await app.refreshKanbanColumnCounts();
                    } catch (e) {
                        console.warn('refreshKanbanColumnCounts', e);
                    }
                }, 500);
            },

            loadKanbanColumnPage: async (stageName, reset) => {
                if (app.shouldSkipKanbanColumn(stageName)) {
                    return;
                }
                let st = app.kanbanColState[stageName];
                if (!st) {
                    st = { offset: 0, loading: false, hasMore: true, serverTotal: 0 };
                    app.kanbanColState[stageName] = st;
                }
                if (reset) {
                    st.offset = 0;
                    st.hasMore = (st.serverTotal || 0) > 0;
                    const list = document.querySelector(`.kanban-list[data-stage="${CSS.escape(stageName)}"]`);
                    if (list) {
                        list.innerHTML = '';
                    }
                }
                if (st.loading || !st.hasMore) {
                    return;
                }
                st.loading = true;
                const pageSize = app.kanbanPageSize || 60;
                let q = app.sb.from('oportunidades').select('*');
                q = app.applyOportunidadesDbFilters(q, { mode: 'kanbanPage', etapaNome: stageName });
                if (!q) {
                    st.loading = false;
                    st.hasMore = false;
                    return;
                }
                q = q
                    .order('retorno', { ascending: true })
                    .order('id', { ascending: true })
                    .range(st.offset, st.offset + pageSize - 1);

                try {
                    const { data, error } = await q;
                    if (error) {
                        throw error;
                    }
                    const batch = data || [];
                    const list = document.querySelector(`.kanban-list[data-stage="${CSS.escape(stageName)}"]`);
                    for (const raw of batch) {
                        const op = { ...raw };
                        app.enrichOp(op);
                        if (!app.applyOpFilters(op)) {
                            continue;
                        }
                        if (op.excluido || op.status !== 'aberto' || op.etapa_nome !== stageName) {
                            continue;
                        }
                        app.mergeOportunidadeIntoCache(op);
                        if (list) {
                            const newEl = ui.createCard(op);
                            app._insertCardSorted(list, newEl, op);
                        }
                    }
                    st.offset += batch.length;
                    if (batch.length < pageSize) {
                        st.hasMore = false;
                    }
                } catch (e) {
                    console.error('Erro ao carregar coluna kanban', stageName, e);
                    st.hasMore = false;
                } finally {
                    st.loading = false;
                }
            },

            bootstrapKanbanColumns: async () => {
                if (!app.isKanbanCardMode() || !app.etapas) {
                    return;
                }
                await Promise.all(app.etapas.map(e => app.loadKanbanColumnPage(e.nome, true)));
                app.attachKanbanColumnScrollListeners();
            },

            loadListaPage: async (reset) => {
                if (app.listaLoading) {
                    return;
                }
                if (reset) {
                    app.listaOportunidades = [];
                    app.listaQueryOffset = 0;
                    app.listaHasMore = true;
                }
                if (!app.listaHasMore && !reset) {
                    return;
                }
                app.listaLoading = true;
                const pageSize = app.listaPageSize || 80;
                let q = app.sb.from('oportunidades').select('*');
                q = app.applyOportunidadesDbFilters(q, { mode: 'lista' });
                if (!q) {
                    app.listaLoading = false;
                    app.listaHasMore = false;
                    ui.renderListTable();
                    app.syncListaLoadMoreButton();
                    return;
                }
                q = q.order('criado_em', { ascending: false }).range(app.listaQueryOffset, app.listaQueryOffset + pageSize - 1);
                try {
                    const { data, error } = await q;
                    if (error) {
                        throw error;
                    }
                    const batch = data || [];
                    for (const raw of batch) {
                        const op = { ...raw };
                        app.enrichOp(op);
                        if (!app.applyOpFilters(op)) {
                            continue;
                        }
                        app.mergeOportunidadeIntoCache(op);
                        app.listaOportunidades.push(op);
                    }
                    app.listaQueryOffset += batch.length;
                    app.listaHasMore = batch.length === pageSize;
                } catch (e) {
                    console.error('Erro loadListaPage', e);
                    app.listaHasMore = false;
                } finally {
                    app.listaLoading = false;
                }
                app.sortList(app.currentSortCol, true);
                app.syncListaLoadMoreButton();
            },

            syncListaLoadMoreButton: () => {
                const btn = document.getElementById('btn-lista-load-more');
                if (!btn) return;
                const listaVis = document.getElementById('board-lista') && !document.getElementById('board-lista').classList.contains('hidden');
                const show = listaVis && app.listaHasMore;
                btn.classList.toggle('hidden', !show);
            },

            loadNegociosGanhosCache: async () => {
                const batchSize = 1000;
                let offset = 0;
                const all = [];
                try {
                    while (true) {
                        let q = app.sb.from('oportunidades').select('*')
                            .eq('funil_id', config.activePipeline)
                            .eq('status', 'ganho')
                            .eq('excluido', false)
                            .order('criado_em', { ascending: false })
                            .range(offset, offset + batchSize - 1);
                        if (!app.isGerente && app.user && app.user.id) {
                            q = q.eq('corretor_id', app.user.id);
                        }
                        const { data, error } = await q;
                        if (error) {
                            throw error;
                        }
                        const batch = data || [];
                        batch.forEach(o => app.enrichOp(o));
                        all.push(...batch);
                        if (batch.length < batchSize) {
                            break;
                        }
                        offset += batchSize;
                    }
                } catch (e) {
                    console.error('Erro loadNegociosGanhosCache', e);
                }
                app.negociosGanhosCache = all;
            },

            loadMetricsOpsSnapshot: async () => {
                const batchSize = 1000;
                let offset = 0;
                const all = [];
                try {
                    while (true) {
                        let q = app.sb.from('oportunidades').select('*')
                            .eq('funil_id', config.activePipeline)
                            .eq('excluido', false)
                            .order('criado_em', { ascending: false })
                            .range(offset, offset + batchSize - 1);
                        if (!app.isGerente && app.user && app.user.id) {
                            q = q.eq('corretor_id', app.user.id);
                        }
                        const { data, error } = await q;
                        if (error) {
                            throw error;
                        }
                        const batch = data || [];
                        batch.forEach(o => app.enrichOp(o));
                        all.push(...batch);
                        if (batch.length < batchSize) {
                            break;
                        }
                        offset += batchSize;
                    }
                } catch (e) {
                    console.error('Erro loadMetricsOpsSnapshot', e);
                }
                app._metricsOps = all;
            },

            loadData: async () => {
                try {
                    app.teardownKanbanScrollListeners();
                    app.oportunidades = [];
                    app.kanbanColState = {};
                    app.listaOportunidades = [];
                    app.listaQueryOffset = 0;
                    app.listaHasMore = true;

                    const {data: etapas, error: errEtapas} = await app.sb.from('etapas_funil').select('*').eq('funil_id', config.activePipeline).order('ordem');
                    if (errEtapas) {
                        console.error("Erro etapas:", errEtapas);
                    }
                    app.etapas = etapas || [];
                    ui.renderBoard(app.etapas);

                    const selFilterEtapa = document.getElementById('filter-etapa');
                    if (selFilterEtapa) {
                        const prevEtapa = selFilterEtapa.value;
                        selFilterEtapa.innerHTML = '<option value="">Todas as etapas</option>' +
                            app.etapas.map(e => `<option value="${e.nome}">${e.nome}</option>`).join('');
                        if (prevEtapa && app.etapas.some(e => e.nome === prevEtapa)) {
                            selFilterEtapa.value = prevEtapa;
                        }
                    }

                    if (app.isKanbanCardMode()) {
                        await app.refreshKanbanColumnCounts();
                        await app.bootstrapKanbanColumns();
                    } else {
                        document.querySelectorAll('.kanban-col').forEach((col) => {
                            const stageEl = col.querySelector('.kanban-list');
                            const stage = stageEl?.dataset?.stage;
                            if (stage) {
                                app.kanbanColState[stage] = { offset: 0, loading: false, hasMore: false, serverTotal: 0 };
                                app.setKanbanBadge(stage, 0);
                            }
                            if (stageEl) {
                                stageEl.innerHTML = '';
                            }
                        });
                        app.refreshHeaderPendenteFromServerTotals();
                    }

                    await app.loadNegociosGanhosCache();
                    ui.renderSeguradosTable();

                    const listaVisivel = !document.getElementById('board-lista').classList.contains('hidden');
                    if (listaVisivel) {
                        await app.loadListaPage(true);
                    } else {
                        ui.renderListTable();
                        app.syncListaLoadMoreButton();
                    }

                    if (!document.getElementById('view-dashboard').classList.contains('hidden')) {
                        await app.loadMetricsOpsSnapshot();
                        app.updateDashboard();
                    }

                } catch (error) {
                    console.error("Erro no loadData:", error);
                }
            },

            sortList: (col, forceCurrentDirection = false) => {
                if (!forceCurrentDirection) {
                    if (app.currentSortCol === col) {
                        app.currentSortAsc = !app.currentSortAsc;
                    } else {
                        app.currentSortCol = col;
                        app.currentSortAsc = true;
                    }
                }
                
                const listaArr = app.listaOportunidades || [];
                listaArr.sort((a, b) => {
                    let valA = a[col] || '';
                    let valB = b[col] || '';

                    if (col === 'ramo') {
                        const ramoA = String(ui.oportunidadeRamoExibicao(a) || '');
                        const ramoB = String(ui.oportunidadeRamoExibicao(b) || '');
                        const cmp = ramoA.localeCompare(ramoB, 'pt-BR');
                        return app.currentSortAsc ? cmp : -cmp;
                    }
                    
                    if (col === 'etapa_nome') {
                        const etapaA = app.etapas.find(e => e.nome === a.etapa_nome);
                        const etapaB = app.etapas.find(e => e.nome === b.etapa_nome);
                        valA = etapaA ? etapaA.ordem : 99;
                        valB = etapaB ? etapaB.ordem : 99;
                    }

                    if (col === 'status') {
                        const ord = { aberto: 0, ganho: 1, perdido: 2 };
                        valA = ord[a.status] !== undefined ? ord[a.status] : 9;
                        valB = ord[b.status] !== undefined ? ord[b.status] : 9;
                    }

                    if (col === 'is_checked') {
                        valA = a.is_checked === true ? 1 : 0;
                        valB = b.is_checked === true ? 1 : 0;
                    }

                    if (col === 'nome_corretor') {
                        const ca = String(a.nome_corretor || '').localeCompare(String(b.nome_corretor || ''), 'pt-BR');
                        return app.currentSortAsc ? ca : -ca;
                    }
                    
                    if (col === 'nome_segurado') {
                        const na = String(ui.tituloOportunidadeExibicao(a) || '');
                        const nb = String(ui.tituloOportunidadeExibicao(b) || '');
                        const c = na.localeCompare(nb, 'pt-BR');
                        return app.currentSortAsc ? c : -c;
                    }

                if (valA < valB) return app.currentSortAsc ? -1 : 1;
                if (valA > valB) return app.currentSortAsc ? 1 : -1;
                return 0;
            });
                
                ui.renderListTable();
            },

            updateKanbanCounts: () => {
                app.refreshHeaderPendenteFromServerTotals();
            },

            syncKanbanOpFromRecord: (payload) => {
                const { eventType, new: newRec, old: oldRec } = payload;
                const id = newRec ? newRec.id : (oldRec ? oldRec.id : null);
                if (!id) return;

                const existingIdx = app.oportunidades.findIndex(o => String(o.id) === String(id));
                const existingEl = document.querySelector(`.kanban-list [data-id="${id}"]`);

                if (eventType === 'DELETE') {
                    if (existingIdx > -1) app.oportunidades.splice(existingIdx, 1);
                    if (existingEl) existingEl.remove();
                    app.scheduleKanbanCountsDebounced();
                    app.refreshHeaderPendenteFromServerTotals();
                    return;
                }

                if (!newRec) return;

                // Merge com o que já existe (para preservar contatos/corretores caso payload seja parcial)
                let op = { ...newRec };
                if (existingIdx > -1) {
                    op = { ...app.oportunidades[existingIdx], ...newRec };
                }

                app.enrichOp(op);
                const matches = app.applyOpFilters(op) && !op.excluido && op.status === 'aberto';

                if (!matches) {
                    if (existingIdx > -1) app.oportunidades.splice(existingIdx, 1);
                    if (existingEl) existingEl.remove();
                } else {
                    if (existingIdx > -1) {
                        app.oportunidades[existingIdx] = op;
                    } else {
                        app.oportunidades.push(op);
                    }

                    const targetStage = op.etapa_nome;
                    const col = document.querySelector(`.kanban-list[data-stage="${targetStage}"]`);
                    
                    if (existingEl) existingEl.remove();

                    if (col) {
                        const newEl = ui.createCard(op);
                        app._insertCardSorted(col, newEl, op);
                    }
                }
                
                app.scheduleKanbanCountsDebounced();
                app.refreshHeaderPendenteFromServerTotals();
            },

            _insertCardSorted: (col, newEl, op) => {
                const dataOp = op.retorno ? new Date(`${op.retorno}T12:00:00`).getTime() : Number.POSITIVE_INFINITY;
                const cards = Array.from(col.children);
                let inserted = false;

                for (let i = 0; i < cards.length; i++) {
                    const cardId = cards[i].dataset.id;
                    const siblingOp = app.oportunidades.find(o => String(o.id) === cardId);
                    if (siblingOp) {
                        const dataSib = siblingOp.retorno ? new Date(`${siblingOp.retorno}T12:00:00`).getTime() : Number.POSITIVE_INFINITY;
                        let shouldInsertBefore = false;
                        
                        if (dataOp < dataSib) {
                            shouldInsertBefore = true;
                        } else if (dataOp === dataSib) {
                            if (String(ui.tituloOportunidadeExibicao(op) || '').localeCompare(String(ui.tituloOportunidadeExibicao(siblingOp) || ''), 'pt-BR') < 0) {
                                shouldInsertBefore = true;
                            }
                        }

                        if (shouldInsertBefore) {
                            col.insertBefore(newEl, cards[i]);
                            inserted = true;
                            break;
                        }
                    }
                }

                if (!inserted) {
                    col.appendChild(newEl);
                }
            },

            renderKanban: () => {
                document.querySelectorAll('.kanban-list').forEach(el => {
                    el.innerHTML = '';
                });
                
                let pendentesCount = 0;

                const oportunidadesOrdenadas = [...app.oportunidades].sort((a, b) => {
                    const dataA = a.retorno ? new Date(`${a.retorno}T12:00:00`).getTime() : Number.POSITIVE_INFINITY;
                    const dataB = b.retorno ? new Date(`${b.retorno}T12:00:00`).getTime() : Number.POSITIVE_INFINITY;
                    if (dataA !== dataB) return dataA - dataB;
                    return String(ui.tituloOportunidadeExibicao(a) || '').localeCompare(String(ui.tituloOportunidadeExibicao(b) || ''), 'pt-BR');
                });

                oportunidadesOrdenadas.forEach(d => {
                    if (d.excluido) {
                        return;
                    }
                    if (d.status !== 'aberto') {
                        return;
                    }
                    const targetStage = d.etapa_nome;
                    const col = document.querySelector(`.kanban-list[data-stage="${targetStage}"]`);
                    if (col) {
                        col.appendChild(ui.createCard(d));
                        pendentesCount++;
                    }
                });
                
                const headerLeads = document.getElementById('header-total-leads');
                if (headerLeads) {
                    headerLeads.innerText = `${pendentesCount} pendentes`;
                }
                
                app.updateKanbanCounts();
            },

