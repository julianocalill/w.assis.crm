            buildReagendamentoResumoHtml: () => {
                const esc = (s) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
                const fmtDateBR = (iso) => {
                    if (!iso || typeof iso !== 'string') return '-';
                    const t = iso.trim().split('T')[0];
                    if (!t) return '-';
                    const parts = t.split('-');
                    if (parts.length !== 3) return '-';
                    const y = parseInt(parts[0], 10);
                    const mo = parseInt(parts[1], 10);
                    const da = parseInt(parts[2], 10);
                    if (Number.isNaN(y) || Number.isNaN(mo) || Number.isNaN(da)) return '-';
                    const dt = new Date(y, mo - 1, da);
                    if (dt.getFullYear() !== y || dt.getMonth() !== mo - 1 || dt.getDate() !== da) return '-';
                    return dt.toLocaleDateString('pt-BR');
                };
                const p = ui.produtos[0] || {};
                const nome = esc((document.getElementById('modal-header-nome')?.value || document.getElementById('opNome')?.value || '-').trim());
                const email = esc((document.getElementById('opEmail')?.value || '-').trim());
                const doc = esc((document.getElementById('opDocumento')?.value || '-').trim());
                const telefone = esc((document.getElementById('opTelefone')?.value || '-').trim());
                const origem = esc((document.getElementById('opOrigem')?.value || '-').trim());
                const vigencia = esc(fmtDateBR(document.getElementById('opVigencia')?.value || '-'));
                const ramo = esc(p.ramo || '-');
                const tipo = esc(p.tipo || '-');
                const seguradora = esc((document.getElementById('opSeguradora')?.value || '-').trim());
                const premio = formatBRL(parseFloat(p.premio) || 0);
                const com = ui.fmtPctBR(p.comissao);
                const rows = [
                    ['Nome', nome],
                    ['E-mail', email],
                    ['Telefone', telefone],
                    ['CPF/CNPJ', doc],
                    ['Origem', origem],
                    ['Vigência', vigencia],
                    ['Ramo', ramo],
                    ['Novo?', tipo],
                    ['Seguradora', seguradora],
                    ['Prêmio líquido', premio],
                    ['Comissão (%)', `${com}%`]
                ];
                return `<div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">${rows.map(([label, value]) => `<p class="leading-relaxed"><strong>${label}:</strong> ${value}</p>`).join('')}</div>`;
            },

            addProduto: () => {
                if (ui.produtos.length >= 1) {
                    return;
                }

                const defaultRamo = app.ramos.length > 0 ? app.ramos[0].nome : 'Automóvel';
                
                ui.produtos.push({ 
                    id: Date.now(), 
                    ramo: defaultRamo, 
                    tipo: 'Novo', 
