            loadAllContatos: async () => {
                const batchSize = 1000;
                let offset = 0;
                const contatos = [];

                while (true) {
                    const { data, error } = await app.sb
                        .from('contatos')
                        .select('*')
                        .order('id', { ascending: true })
                        .range(offset, offset + batchSize - 1);

                    if (error) {
                        throw error;
                    }

                    const batch = data || [];
                    contatos.push(...batch);
                    if (batch.length < batchSize) {
                        break;
                    }

                    offset += batchSize;
                }

                contatos.sort((a, b) => (a.nome || '').localeCompare(b.nome || '', 'pt-BR'));
                return contatos;
            },

