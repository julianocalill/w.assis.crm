                    (parseFloat(d.comissao_percentual) || 0) !== 0 ||
                    (parseFloat(d.agenciamento_percentual) || 0) !== 0;
                if (temColunas1x1 || !d.produtos || !Array.isArray(d.produtos) || d.produtos.length === 0) {
