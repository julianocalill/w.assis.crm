                if (app.isSelectingContatoModalRole === role) return;

                const f = MODAL_CONTATO_FIELDS[role];
                if (!f) return;

                const hidden = document.getElementById(f.hiddenId);
                const tinhaVinculo = !!(hidden && hidden.value);
                if (hidden) hidden.value = '';

                const status = document.getElementById(f.status);
                if (status && tinhaVinculo) {
                    status.innerText = 'Contato desvinculado por edição manual. Será salvo como novo cadastro.';
                }

                if (fieldName === 'nome' || fieldName === 'documento' || fieldName === 'telefone') {
                    app.onBuscaContatoModalInput(role, value);
