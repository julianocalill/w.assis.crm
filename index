            moveDeal: async (id, toStage, fromStage) => {
                const d = app.oportunidades.find(o => String(o.id) === String(id));
                if (!d || d.status !== 'aberto') {
                    await app.loadData();
                    return;
                }
                
                d.etapa_nome = toStage;

                const cardEl = document.querySelector(`.kanban-list [data-id="${id}"]`);
                const destCol = document.querySelector(`.kanban-list[data-stage="${toStage}"]`);
                if (cardEl && destCol) {
                    cardEl.remove();
                    app._insertCardSorted(destCol, cardEl, d);
                }

                app.adjustKanbanColumnTotal(fromStage, -1);
                app.adjustKanbanColumnTotal(toStage, 1);
                
                app.suppressRealtimeBoardSync();
                await app.sb.from('oportunidades').update({ etapa_nome: toStage }).eq('id', id);
                app.logTimeline(id, 'Movimentação', `O card foi movido da coluna "${fromStage}" para "${toStage}".`, true);
            },

