                const pageSize = app.contatosPageSize || 15;
                const totalPages = Math.max(1, Math.ceil((totalItems || 0) / pageSize));
                app.contatosPage = Math.min(Math.max(1, app.contatosPage || 1), totalPages);
                const currentPage = app.contatosPage;
                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;

                return {
                    totalItems: totalItems || 0,
                    pageSize,
                    totalPages,
                    currentPage,
                    start,
                    end
                };
            },

