                    const nomeCorretorEsc = String(d.nome_corretor || '—').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
                    const profCell = app.isGerente
                        ? `<td class="px-6 py-4 text-textMuted text-xs font-semibold">${nomeCorretorEsc}</td>`
                        : '';

                    const precisaConf = d.excluido === true || st === 'ganho' || st === 'perdido';
                    const confCell = !precisaConf
                        ? `<td class="px-6 py-4 text-center text-xs text-textMuted" title="Conferência após fechar ou excluir">—</td>`
