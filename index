                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                event: 'fechamento',
                                outcome: 'perdido',
                                tipo_funil: tf,
                                fila: {
                                    motivoId: motivoStep.id,
                                    motivoNome: motivoStep.nome,
