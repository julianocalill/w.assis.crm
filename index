            updateProfile: async () => {
                const btn = document.getElementById('btnSaveProfile');
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...';
                btn.disabled = true;
                
                try {
                    const novoNome = document.getElementById('profileNome').value;
                    const novaSenha = document.getElementById('profileSenha').value;
                    const fileInput = document.getElementById('avatarUploadInput');
                    
                    let avatarUrl = null;
                    if (fileInput.files.length > 0) {
                        const file = fileInput.files[0];
                        const fileName = `${app.user.id}_${Date.now()}.${file.name.split('.').pop()}`;
                        
                        const {error: upErr} = await app.sb.storage.from('avatares').upload(fileName, file);
                        if (upErr) {
                            throw new Error("Sem permissão para upload da foto. Verifique a Policy do bucket.");
                        }
                        
                        avatarUrl = app.sb.storage.from('avatares').getPublicUrl(fileName).data.publicUrl;
                    }

                    const updateData = { nome_completo: novoNome };
                    
                    if (avatarUrl) {
                        updateData.avatar_url = avatarUrl;
                    }
                    
                    const {error: dbErr} = await app.sb.from('corretores').update(updateData).eq('id', app.user.id);
                    if (dbErr) {
                        throw new Error("Erro ao salvar nome no banco de dados.");
                    }

                    if (novaSenha && novaSenha.trim() !== '') {
                        const {error: passErr} = await app.sb.auth.updateUser({ password: novaSenha });
                        if (passErr) {
                            throw new Error("A nova senha deve ter no mínimo 6 caracteres.");
                        }
                    }

                    if (novoNome) {
                        document.getElementById('user-name').innerText = novoNome;
                    }
                    
                    if (avatarUrl) {
                        const bgUrl = `url('${avatarUrl}')`;
                        document.getElementById('user-avatar').innerHTML = ''; 
                        document.getElementById('user-avatar').style.backgroundImage = bgUrl;
                        document.getElementById('profile-modal-avatar').innerHTML = ''; 
                        document.getElementById('profile-modal-avatar').style.backgroundImage = bgUrl;
                    }

                    Swal.fire({toast: true, position: 'top-end', icon: 'success', title: 'Perfil salvo!', showConfirmButton: false, timer: 1500});
                    ui.closeProfileModal();

                } catch(e) {
                    Swal.fire('Ops', e.message, 'warning');
                } finally {
                    btn.innerHTML = 'Salvar Perfil';
                    btn.disabled = false;
                }
            },

