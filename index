            buscarChatwoot: async (role = 'segurado') => {
                const f = MODAL_CONTATO_FIELDS[role] || MODAL_CONTATO_FIELDS.segurado;
                let telRaw = document.getElementById(f.telefone).value;
                if(!telRaw) {
                    return;
                }

                let cleanPhone = telRaw.replace(/\D/g, '');
                
                if (cleanPhone.length < 10) {
                    return Swal.fire('Atenção', 'Digite um número de telefone válido com DDD (ex: 11999999999).', 'warning');
                }

                const cwUrl = localStorage.getItem('nexus_cw_url') || config.cwUrl;
                const cwAccount = localStorage.getItem('nexus_cw_account') || config.cwAccount;
                const cwToken = localStorage.getItem('nexus_cw_token') || config.cwToken;

                if (!cwUrl || !cwToken || cwUrl === 'URL_DO_CHATWOOT') {
                    return Swal.fire('Integração Ausente', 'Configure a URL e o Token do Chatwoot no menu Configurações > Integrações API.', 'info');
                }

                const inputCw = document.getElementById(f.chatwoot);
                
                if (cleanPhone.length === 10 || cleanPhone.length === 11) {
                    cleanPhone = '55' + cleanPhone;
                }
                const phoneQuery = '+' + cleanPhone;

                const btnBusca = document.getElementById(f.btnChatwoot);
                const originalBtnText = btnBusca.innerHTML;
                btnBusca.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
                btnBusca.disabled = true;

                inputCw.placeholder = "Buscando na nuvem...";
                
                try {
                    const searchRes = await fetch(`${cwUrl}/api/v1/accounts/${cwAccount}/contacts/search?q=${encodeURIComponent(phoneQuery)}`, {
                        headers: { 'api_access_token': cwToken }
                    });
                    
                    if (!searchRes.ok) throw new Error('Falha API');
                    
                    const contactData = await searchRes.json();
                    
                    if (contactData.payload && contactData.payload.length > 0) {
                        const contactId = contactData.payload[0].id;
                        
                        const convRes = await fetch(`${cwUrl}/api/v1/accounts/${cwAccount}/contacts/${contactId}/conversations`, {
                            headers: { 'api_access_token': cwToken }
                        });
                        const convData = await convRes.json();
                        
                        if (convData.payload && convData.payload.length > 0) {
                            inputCw.value = convData.payload[0].id;
                            Swal.fire({toast: true, position: 'top-end', icon: 'success', title: 'Conversa Encontrada!', showConfirmButton: false, timer: 2000});
                        } else {
                            Swal.fire('Aviso', 'Nenhuma conversa ativa foi encontrada para esse contato.', 'info');
                            inputCw.placeholder = "Sem conversa ativa";
                        }
                    } else {
                        Swal.fire('Aviso', 'Nenhuma conversa ativa foi encontrada para esse contato.', 'info');
                        inputCw.placeholder = "Sem conversa ativa";
                    }
                    
                } catch (error) {
                    console.error("Erro Chatwoot:", error);
                    Swal.fire('Erro', 'Falha ao buscar no Chatwoot (CORS ou erro de rede).', 'error');
                    inputCw.placeholder = "Erro de conexão API";
                } finally {
                    btnBusca.innerHTML = originalBtnText;
                    btnBusca.disabled = false;
                }
            },

            normalizeDigits: (v) => (v || '').toString().replace(/\D/g, ''),

            normalizeText: (v) => (v || '').toString().trim().toLowerCase(),

            escapeHtml: (v) => (v || '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
