<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>W.Assis CRM | Seguros</title>
    
    <link rel="icon" type="image/png" href="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 
                        primary: '#0263E0', 
                        surface: '#FFFFFF', 
                        bg: '#F8FAFC', 
                        border: '#E2E8F0', 
                        textMain: '#1E293B', 
                        textMuted: '#64748B', 
                        danger: '#DC2626' 
                    },
                    fontFamily: { 
                        sans: ['Inter', 'sans-serif'] 
                    }
                }
            }
        }
    </script>

    <style>
        body { 
            background-color: #F8FAFC; 
            color: #1E293B; 
            font-family: 'Inter', sans-serif; 
        }
        
        /* Barra de Rolagem (Scrollbars) */
        ::-webkit-scrollbar { 
            width: 8px; 
            height: 8px; 
        }
        
        ::-webkit-scrollbar-thumb { 
            background: #CBD5E1; 
            border-radius: 4px; 
        }
        
        ::-webkit-scrollbar-track { 
            background: transparent; 
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb { 
            background: #94A3B8; 
        }
        
        /* Efeitos visuais do Kanban */
        .ghost-card { 
            background: #EFF6FF; 
            border: 2px dashed #0263E0; 
            opacity: 0.7; 
        }
        
        .handle { 
            cursor: grab; 
        }
        
        .handle:active { 
            cursor: grabbing; 
        }

        /* Configuração das Colunas Dinâmicas do Kanban */
        .kanban-col { 
            min-width: 320px; 
            width: 320px; 
            flex-shrink: 0; 
            transition: width 0.3s ease, min-width 0.3s ease; 
        }
        
        .kanban-col.collapsed { 
            min-width: 52px; 
            width: 52px; 
            background-color: #F1F5F9; 
            border: 1px dashed #CBD5E1; 
            border-radius: 1rem; 
        }
        
        .kanban-col.collapsed .col-header-full, 
        .kanban-col.collapsed .kanban-list { 
            display: none !important; 
        }
        
        .col-header-collapsed { 
            display: none; 
        }
        
        .kanban-col.collapsed .col-header-collapsed { 
            display: flex; 
        }
        
        .vertical-text { 
            writing-mode: vertical-rl; 
            transform: rotate(180deg); 
            letter-spacing: 0.05em; 
        }

        /* Navegação da Sidebar Esquerda */
        .nav-item.active { 
            background-color: #0263E0; 
            color: #FFFFFF; 
            font-weight: 600; 
        }
        
        .nav-item.active i { 
            color: #FFFFFF; 
        }
        
        /* Sidebar principal — largura e colapso */
        .sidebar-app {
            width: 256px;
            min-width: 256px;
            flex-shrink: 0;
            transition: width 0.2s ease, min-width 0.2s ease;
        }
        
        .sidebar-app.sidebar-collapsed {
            width: 72px;
            min-width: 72px;
        }
        
        .sidebar-app.sidebar-collapsed .nav-label {
            display: none;
        }
        
        .sidebar-app.sidebar-collapsed .sidebar-logo {
            display: none;
        }
        
        .sidebar-app.sidebar-collapsed .sidebar-header {
            justify-content: center;
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        
        .sidebar-app.sidebar-collapsed .nav-item,
        .sidebar-app.sidebar-collapsed .sidebar-footer-btn {
            justify-content: center;
            gap: 0;
        }
        
        .sidebar-app.sidebar-collapsed nav {
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        
        .sidebar-app.sidebar-collapsed .sidebar-footer {
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        
        /* Estilização das Abas Superiores do Modal do Card */
        .modal-tab-btn { 
            padding-bottom: 0.5rem; 
            color: #64748B; 
            font-weight: 500; 
            font-size: 0.8rem; 
            border-bottom: 2px solid transparent; 
            transition: all 0.2s; 
            cursor: pointer; 
            background: none; 
        }
        
        .modal-tab-btn.active { 
            color: #DC2626; 
            font-weight: 700; 
            border-bottom-color: #DC2626; 
        }
        
        .modal-tab-btn:hover:not(.active) { 
            color: #1E293B; 
        }
        
        /* Estilização das Abas Laterais do Modal de Configurações */
        .settings-tab-btn {
            width: 100%; 
            text-align: left; 
            padding: 0.75rem 1rem; 
            border-radius: 0.5rem; 
            color: #64748B; 
            font-weight: 600; 
            transition: all 0.2s; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            gap: 0.75rem;
        }
        
        .settings-tab-btn.active { 
            background-color: #EFF6FF; 
            color: #0263E0; 
        }
        
        .settings-tab-btn:hover:not(.active) { 
            background-color: #F8FAFC; 
            color: #1E293B; 
        }

        /* Botão de Upload de Arquivos Personalizado */
        input[type="file"]::file-selector-button { 
            background-color: #0263E0; 
            color: white; 
            border: none; 
            padding: 0.5rem 1rem; 
            border-radius: 0.5rem; 
            font-weight: 600; 
            cursor: pointer; 
            transition: background-color 0.2s; 
        }
        
        input[type="file"]::file-selector-button:hover { 
            background-color: #1d4ed8; 
        }
        
        /* Ajustes Visuais BI (Sprint 3) */
        .bi-card {
            border-left: 4px solid #0263E0;
        }
        .bi-card-emerald {
            border-left: 4px solid #10B981;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden text-sm">

    <div id="loginOverlay" class="fixed inset-0 bg-bg z-[200] flex items-center justify-center">
        <div class="bg-surface p-10 rounded-2xl shadow-xl border border-border w-[400px]">
            <div class="flex justify-center mb-8">
                <img src="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png" alt="W.Assis Seguros" class="h-12 object-contain">
            </div>
            
            <form id="loginForm" onsubmit="event.preventDefault(); app.login(event); return false;" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-textMuted mb-1 uppercase tracking-wider">E-mail Corporativo</label>
                    <input type="email" id="loginEmail" required class="w-full border border-border rounded-lg p-3 outline-none focus:border-primary transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-textMuted mb-1 uppercase tracking-wider">Senha</label>
                    <input type="password" id="loginPassword" required class="w-full border border-border rounded-lg p-3 outline-none focus:border-primary transition">
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-blue-700 text-white font-bold py-3 rounded-lg shadow-lg mt-2 transition">
                    Entrar no Sistema
                </button>
            </form>
            <div id="loginLoading" class="hidden text-center text-sm text-textMuted font-semibold py-6">
                Carregando perfil...
            </div>
        </div>
    </div>

    <aside id="app-sidebar" class="sidebar-app bg-surface border-r border-border flex flex-col h-full z-20 shadow-sm">
        <div class="h-20 flex items-center justify-between px-3 border-b border-border shrink-0 sidebar-header">
            <img src="https://wassis.com.br/wp-content/uploads/2023/02/wassis-logo.png" alt="W.Assis Seguros" class="sidebar-logo h-8 object-contain max-w-[140px]">
            <button type="button" id="sidebarToggle" onclick="ui.toggleSidebar()" class="shrink-0 rounded-lg p-2 text-textMuted hover:bg-slate-100 transition" aria-expanded="true" aria-controls="app-sidebar" title="Recolher menu">
                <i class="fa-solid fa-angles-left"></i>
            </button>
        </div>
        
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto overflow-x-hidden">
            <button type="button" onclick="app.navigate('oportunidades')" id="nav-oportunidades" title="Oportunidades" class="nav-item active flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-handshake w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Oportunidades</span>
            </button>
            
            <button type="button" onclick="app.navigate('contatos')" id="nav-contatos" title="Contatos" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-regular fa-address-book w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Contatos</span>
            </button>

            <button type="button" onclick="app.navigate('dashboard')" id="nav-dashboard" title="Analytics" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-chart-pie w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Analytics</span>
            </button>
            
            <button type="button" onclick="app.navigate('segurados')" id="nav-segurados" title="Segurados ativos" class="nav-item flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-shield-halved w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Segurados Ativos</span>
            </button>
        </nav>
        
        <div class="p-4 border-t border-border sidebar-footer">
            <button type="button" id="sidebar-settings-btn" onclick="ui.openSettingsModal()" title="Configurações" class="sidebar-footer-btn flex items-center gap-3 w-full px-4 py-3 rounded-xl text-textMuted hover:bg-slate-100 transition">
                <i class="fa-solid fa-gear w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Configurações</span>
            </button>
            
            <button type="button" onclick="app.logout()" title="Sair" class="sidebar-footer-btn flex items-center gap-3 w-full px-4 py-3 mt-2 rounded-xl text-red-500 hover:bg-red-50 transition">
                <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center shrink-0"></i><span class="nav-label whitespace-nowrap">Sair</span>
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full bg-bg relative min-w-0">
        
        <header class="h-20 bg-surface border-b border-border px-8 flex justify-between items-center z-10 shadow-sm shrink-0">
            <div id="globalSearchWrap" class="relative w-96 hidden md:block">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-textMuted pointer-events-none z-[1]" aria-hidden="true"></i>
                <input id="globalSearchInput" type="search" autocomplete="off"
                    placeholder="Buscar no sistema..."
                    aria-label="Buscar contatos e oportunidades"
                    aria-expanded="false"
                    aria-controls="globalSearchPanel"
                    aria-autocomplete="list"
                    class="w-full bg-slate-100 border border-transparent focus:border-border rounded-full py-2.5 pl-11 pr-4 text-sm outline-none transition focus:bg-white relative z-[1]">
                <div id="globalSearchPanel" class="absolute left-0 right-0 top-full mt-1.5 bg-white border border-border rounded-xl shadow-xl z-[100] max-h-[min(70vh,28rem)] overflow-y-auto hidden text-left" role="listbox" aria-label="Resultados da busca">
                    <div id="globalSearchSummary" class="px-4 py-2.5 border-b border-border text-xs text-textMuted font-medium hidden"></div>
                    <div class="px-3 py-2">
                        <p class="text-[10px] font-bold text-textMuted uppercase tracking-wider mb-1.5">Oportunidades (este funil)</p>
                        <div id="globalSearchOps" class="space-y-0.5"></div>
                    </div>
                    <div class="px-3 py-2 border-t border-border">
                        <p class="text-[10px] font-bold text-textMuted uppercase tracking-wider mb-1.5">Contatos</p>
                        <div id="globalSearchContatos" class="space-y-0.5"></div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center gap-6 ml-auto">
                <div class="flex items-center gap-3 text-right cursor-pointer hover:bg-slate-50 p-2 rounded-xl transition" onclick="ui.openProfileModal()">
                    <div class="hidden md:block">
                        <p id="user-name" class="text-sm font-bold text-textMain leading-tight">Carregando...</p>
                        <p id="user-role" class="text-[10px] font-semibold text-textMuted uppercase tracking-wider">Meu Perfil</p>
                    </div>
                    <div id="user-avatar" class="w-10 h-10 rounded-full bg-slate-200 border-2 border-white shadow-sm flex items-center justify-center text-primary font-bold bg-cover bg-center">
                        <i class="fa-solid fa-user"></i>
                    </div>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-hidden relative">
            
            <div id="view-dashboard" class="h-full overflow-y-auto p-8 hidden">
                <div class="flex justify-between items-end mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-textMain">Painel Executivo</h2>
                        <p class="text-textMuted mt-1"><span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider mr-2">Tempo Real</span> Relatórios e indicadores consolidados.</p>
                    </div>
                    
                    <select id="analytics-pipeline-selector" onchange="app.switchPipeline(this.value)" class="bg-white border border-border rounded-lg px-4 py-2 text-sm text-textMain font-bold outline-none focus:border-primary shadow-sm min-w-[200px]">
                        </select>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-briefcase text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Volume de Negócios</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-count">0</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Oportunidades ativas no funil</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-chart-line text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Prêmio Líquido Total</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-premio">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Soma dos prêmios em negociação</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card-emerald relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-emerald-100"><i class="fa-solid fa-sack-dollar text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-emerald-600 uppercase tracking-wider">Receita Estimada</p>
                        <h3 class="text-3xl font-extrabold text-emerald-600 mt-2" id="kpi-receita">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium">Previsão total de comissionamento</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border bi-card relative overflow-hidden">
                        <div class="absolute right-4 top-4 text-blue-100"><i class="fa-solid fa-calculator text-4xl"></i></div>
                        <p class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Ticket Médio (Prêmio)</p>
                        <h3 class="text-3xl font-extrabold text-textMain mt-2" id="kpi-ticket">R$ 0,00</h3>
                        <p class="text-xs text-textMuted mt-2 font-medium" id="kpi-comissao-perc">Comissão Média: 0%</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 pb-10">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border lg:col-span-2">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3">Distribuição do Funil</h3>
                        <div class="h-64 relative">
                            <canvas id="chartFunil"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3">Share de Produtos</h3>
                        <div class="h-64 relative flex justify-center">
                            <canvas id="chartRamo"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-border lg:col-span-3">
                        <h3 class="font-bold text-textMain text-sm uppercase tracking-wider mb-6 border-b border-border pb-3"><i class="fa-solid fa-trophy text-emerald-500 mr-2"></i> Últimos Fechamentos (Top 5)</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-slate-50 text-[10px] text-textMuted uppercase font-bold border-b border-border">
                                    <tr>
                                        <th class="px-4 py-3">Data</th>
                                        <th class="px-4 py-3">Segurado</th>
                                        <th class="px-4 py-3">Ramo</th>
                                        <th class="px-4 py-3">Produtor</th>
                                        <th class="px-4 py-3 text-right">Receita Gerada</th>
                                    </tr>
                                </thead>
                                <tbody id="dash-recentes-tbody" class="divide-y divide-border text-sm">
                                    </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div id="view-oportunidades" class="h-full flex flex-col">
                
                <div class="px-6 py-4 bg-surface border-b border-border shrink-0">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-extrabold text-textMain">Funil de Vendas</h2>
                        
                        <div class="flex items-center gap-3">
                            <select id="pipeline-selector" onchange="app.switchPipeline(this.value)" class="bg-slate-50 border border-border rounded-lg px-3 py-1.5 text-xs text-textMain outline-none min-w-[150px]">
                                </select>
                            
                            <div class="flex bg-slate-100 p-1 rounded-lg border border-border">
                                <button onclick="ui.toggleView('lista')" id="btn-view-lista" class="px-4 py-1.5 rounded-md text-textMuted font-medium text-xs flex items-center gap-2 transition">
                                    <i class="fa-solid fa-list"></i> Lista
                                </button>
                                
                                <button onclick="ui.toggleView('kanban')" id="btn-view-kanban" class="px-4 py-1.5 rounded-md bg-white shadow-sm text-primary font-bold text-xs flex items-center gap-2 transition">
                                    <i class="fa-solid fa-grip-vertical"></i> Kanban
                                </button>
                            </div>
                            
                            <button onclick="ui.openDealModal()" class="bg-primary hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-bold shadow-sm transition text-xs flex items-center gap-2">
                                <i class="fa-solid fa-plus"></i> Nova Oportunidade
                            </button>
                        </div>
                    </div>
                    
                    <div class="rounded-lg border border-border bg-slate-50 shadow-inner overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-3 py-2 border-b border-border/70 bg-slate-100/90">
                            <span class="text-[10px] font-bold text-textMuted uppercase tracking-wide">Filtros</span>
                            <button type="button" id="btn-toggle-oportunidades-filtros" onclick="ui.toggleOportunidadesFiltros()" aria-controls="oportunidades-filtros-body" aria-expanded="true" class="text-textMuted hover:text-primary transition text-xs font-bold flex items-center gap-1.5 px-2 py-1 rounded-md hover:bg-white/90 border border-transparent hover:border-border">
                                <i id="icon-oportunidades-filtros" class="fa-solid fa-chevron-up text-[10px]"></i>
                                <span id="label-oportunidades-filtros">Recolher filtros</span>
                            </button>
                        </div>
                        <div id="oportunidades-filtros-body" class="p-3 flex flex-wrap gap-3 items-end">
                        <div class="flex-1 min-w-[140px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Datas por</label>
                            <select id="filter-data-campo" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                                <option value="vigencia">Vigência</option>
                                <option value="retorno">Data de retorno</option>
                            </select>
                        </div>
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Data Inicial</label>
                            <input type="date" id="filter-data-ini" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Data Final</label>
                            <input type="date" id="filter-data-fim" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Etapa</label>
                            <select id="filter-etapa" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                                <option value="">Todas as etapas</option>
                            </select>
                        </div>
                        
                        <div class="flex-1 min-w-[120px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Status</label>
                            <select id="filter-status" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                                <option value="">Todos</option>
                                <option value="aberto">Aberto</option>
                                <option value="ganho">Ganho</option>
                                <option value="perdido">Perdido</option>
                                <option value="excluido">Excluído(s)</option>
                            </select>
                        </div>

                        <div class="flex-1 min-w-[140px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Seguradora</label>
                            <select id="filter-seguradora" class="w-full text-xs p-2 rounded border border-border outline-none focus:border-primary bg-white">
                            </select>
                        </div>

                        <div class="flex-1 min-w-[160px]">
                            <label class="text-[9px] font-bold text-textMuted uppercase mb-1 block">Nome do cliente</label>
