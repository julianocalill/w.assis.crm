            populateDropdowns: () => {
                const buildOptions = (arr, defaultText) => {
                    return `<option value="">${defaultText}</option>` + arr.map(i => `<option value="${i.nome}">${i.nome}</option>`).join('');
                };
                
                document.getElementById('opOrigem').innerHTML = buildOptions(app.origens, 'Selecione a Origem...');
                document.getElementById('filter-origem').innerHTML = buildOptions(app.origens, 'Todas as Origens');
                
                document.getElementById('opSeguradora').innerHTML = buildOptions(app.seguradoras, 'Qual seguradora você passou?');
                
                document.getElementById('filter-ramo').innerHTML = buildOptions(app.ramos, 'Todos os Ramos');

                if (!document.getElementById('dealModal').classList.contains('hidden')) {
                    ui.renderProdutos();
                }
            },

            renderConfigList: () => {
                const listEl = document.getElementById('settings-generic-list');
                let data = []; 
                let tableName = '';

                if (ui.currentSettingsTab === 'ramos') { 
                    data = app.ramos; 
                    tableName = 'ramos'; 
                }
                if (ui.currentSettingsTab === 'seguradoras') { 
                    data = app.seguradoras; 
                    tableName = 'seguradoras'; 
                }
                if (ui.currentSettingsTab === 'origens') { 
                    data = app.origens; 
                    tableName = 'origens'; 
                }

                if (data.length === 0) {
                    listEl.innerHTML = `<div class="p-4 text-center text-textMuted bg-slate-50 border border-dashed rounded-lg">Nenhum item cadastrado.</div>`;
                    return;
