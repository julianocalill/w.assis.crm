        const formatDecimalBR2 = (n) => {
            return new Intl.NumberFormat('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(parseFloat(n) || 0);
        };

        const parseDecimalBR = (s) => {
            if (s == null || String(s).trim() === '') return 0;
            const norm = String(s).replace(/\./g, '').replace(',', '.');
            const num = parseFloat(norm);
            if (!Number.isFinite(num)) return 0;
            return Math.round(num * 100) / 100;
        };

        const formatHistoricoDataHora = (iso) => {
            const d = new Date(iso);
            if (Number.isNaN(d.getTime())) {
                return '';
            }
            return d.toLocaleString('pt-BR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                hour12: false
            });
        };

        const escHtml = (txt) => String(txt ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

        const maskDecimalBRInput = (raw) => {
            if (raw == null) return '';
            const str = String(raw);
            const commaIdx = str.indexOf(',');
            let head;
            let tail;
            let hasComma;
            if (commaIdx === -1) {
                head = str;
                tail = '';
                hasComma = false;
            } else {
                head = str.slice(0, commaIdx);
                tail = str.slice(commaIdx + 1);
                hasComma = true;
            }
            const intDigits = head.replace(/\D/g, '').replace(/^0+(?=\d)/, '');
            const decDigits = tail.replace(/\D/g, '').slice(0, 2);

            if (!hasComma && intDigits === '' && str.replace(/\D/g, '') === '') return '';

            const addThousands = (d) => {
                if (!d) return '';
                return d.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            };

            if (!hasComma) {
                if (intDigits === '') return '';
                return addThousands(intDigits);
            }
            const intShow = intDigits === '' ? '0' : addThousands(intDigits);
            return `${intShow},${decDigits}`;
        };

