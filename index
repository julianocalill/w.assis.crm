                const tabs = [
                    'orcamento', 
                    'segurado', 
                    'produtores', 
                    'arquivos', 
                    'historico', 
                    'oportunidades'
                ];
                
                tabs.forEach(t => {
                    document.getElementById(`tab-btn-${t}`).classList.remove('active');
                    document.getElementById(`modal-content-${t}`).classList.add('hidden');
