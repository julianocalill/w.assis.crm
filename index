            createUserN8n: async () => {
                const n8nUserUrl = localStorage.getItem('nexus_n8n_user');
                
                if (!n8nUserUrl) {
                    return Swal.fire('Aviso', 'A URL do webhook (Criar Usuário) não foi configurada na aba de Integrações API.', 'warning');
                }

                const nome = document.getElementById('newUserNome').value.trim();
                const email = document.getElementById('newUserEmail').value.trim();
