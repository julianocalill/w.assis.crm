                    }
                }

                let nomeOportunidadeDeal = titulo || null;
                let responsavelIdFinal = null;
                const formatDateLog = (v) => {
                    if (!v) {
                        return '';
                    }
                    const d = new Date(v);
                    if (Number.isNaN(d.getTime())) {
                        return String(v);
                    }
                    return d.toLocaleDateString('pt-BR');
                };
                const formatValueLog = (field, value) => {
                    if (value === null || value === undefined || value === '') {
                        return '';
                    }
                    if (field === 'retorno' || field === 'vigencia') {
                        return formatDateLog(value);
                    }
                    if (field === 'premio_liquido') {
                        return formatBRL(parseFloat(value) || 0);
                    }
                    if (field === 'comissao_percentual' || field === 'agenciamento_percentual') {
                        return `${ui.fmtPctBR(value)}%`;
                    }
                    if (field === 'ativo') {
                        return value ? 'Ativo' : 'Inativo';
                    }
                    if (field === 'corretor_id') {
                        const cor = app.corretores.find(c => String(c.id) === String(value));
                        return cor?.nome_completo || '';
                    }
                    return String(value);
                };
                const normalizeValueLog = (field, value) => {
                    if (value === null || value === undefined) {
                        return '';
                    }
                    if (field === 'retorno' || field === 'vigencia') {
                        const d = new Date(value);
                        return Number.isNaN(d.getTime()) ? String(value) : d.toISOString().slice(0, 10);
                    }
                    if (field === 'premio_liquido' || field === 'comissao_percentual' || field === 'agenciamento_percentual') {
                        return String(parseFloat(value) || 0);
                    }
                    if (field === 'ativo') {
                        return value ? '1' : '0';
                    }
                    return String(value);
                };

                try {
                    if (!tituloOnly) {
                        if (!contatoId) {
                            const { data: newContato, error: errC } = await app.sb.from('contatos').insert([contatoData]).select();
                            if (errC) {
                                throw errC;
                            }
                            contatoId = String(newContato[0].id);
                            app.contatos.push(newContato[0]);
                            ui.renderContatosTable();
                        } else {
                            await app.sb.from('contatos').update(contatoData).eq('id', contatoId);
                            const ctIndex = app.contatos.findIndex(c => c.id == contatoId);
                            if (ctIndex >= 0) {
                                app.contatos[ctIndex] = { ...app.contatos[ctIndex], ...contatoData };
                            }
                            ui.renderContatosTable();
                        }

                        if (!mesmoResp && respData) {
                            let rid = responsavelId;
                            if (!rid) {
                                const { data: newR, error: errR } = await app.sb.from('contatos').insert([respData]).select();
                                if (errR) {
                                    throw errR;
                                }
                                rid = String(newR[0].id);
                                app.contatos.push(newR[0]);
                                ui.renderContatosTable();
                            } else {
                                await app.sb.from('contatos').update(respData).eq('id', rid);
                                const ri = app.contatos.findIndex(c => c.id == rid);
                                if (ri >= 0) {
                                    app.contatos[ri] = { ...app.contatos[ri], ...respData };
                                }
                                ui.renderContatosTable();
                            }
                            responsavelIdFinal = rid;
                        }

                    } else {
                        contatoId = '';
                        responsavelIdFinal = null;
                    }

                    const defaultRamoSave = app.ramos.length > 0 ? app.ramos[0].nome : 'Automóvel';
                    const p0 = (ui.produtos && ui.produtos[0]) ? ui.produtos[0] : {};
                    const premioLiq = parseFloat(p0.premio) || 0;
                    const comissPct = parseFloat(p0.comissao) || 0;
                    const agencPct = parseFloat(p0.agenciamento) || 0;
                    const valorReceita = premioLiq * ((comissPct + agencPct) / 100);

                    const deal = {
                        contato_id: tituloOnly ? null : contatoId,
                        responsavel_id: responsavelIdFinal,
                        nome_oportunidade: nomeOportunidadeDeal,
                        vigencia: document.getElementById('opVigencia').value || null,
                        retorno: retornoVal,
                        ativo: document.getElementById('opAtivo').checked,
                        origem: document.getElementById('opOrigem').value,
                        seguradora: document.getElementById('opSeguradora').value,
                        ramo_seguro: p0.ramo || defaultRamoSave,
                        tipo_seguro: p0.tipo || 'Novo',
                        premio_liquido: premioLiq,
                        comissao_percentual: comissPct,
                        agenciamento_percentual: agencPct,
                        valor_receita: valorReceita,
                        indicador: document.getElementById('opIndicador').value,
                        corretor_id: document.getElementById('opProdutor').value || app.user.id,
                        etapa_nome: etapa,
                        status: st
                    };

                    if (app.isGerente) {
                        const wrapCh = document.getElementById('dealConferidoWrap');
                        const oc = document.getElementById('opConferido');
                        if (opId && wrapCh && !wrapCh.classList.contains('hidden') && oc) {
                            deal.is_checked = oc.checked;
                        }
                    }

                    if (opAtual) {
                        if (st === 'aberto' && (opAtual.status === 'ganho' || opAtual.status === 'perdido')) {
                            deal.data_fechamento = null;
                            deal.motivo_perda = null;
                        }
                        if (st === 'ganho' && opAtual.status !== 'ganho') {
                            deal.data_fechamento = new Date().toISOString();
                            deal.motivo_perda = null;
                        }
                        if (st === 'perdido' && opAtual.status !== 'perdido') {
                            deal.data_fechamento = new Date().toISOString();
                            deal.motivo_perda = opAtual.motivo_perda || 'Ajuste pelo gerente';
                        }
                    }

                    app.suppressRealtimeBoardSync();
                    if (!opId) {
                        deal.funil_id = config.activePipeline;
                        const { data: newOp, error: errOp } = await app.sb.from('oportunidades').insert([deal]).select();
                        if (errOp) {
                            throw errOp;
                        }
                        const logMsg = tituloOnly
                            ? 'Oportunidade criada (cadastro do segurado pendente).'
                            : 'Oportunidade gerada e atrelada ao contato.';
                        app.logTimeline(newOp[0].id, 'Criação', logMsg, true);
                    } else {
                        const trackedFields = [
                            { key: 'etapa_nome', label: 'etapa' },
                            { key: 'retorno', label: 'data de retorno' },
                            { key: 'premio_liquido', label: 'prêmio líquido' },
                            { key: 'comissao_percentual', label: 'comissão' },
                            { key: 'agenciamento_percentual', label: 'agenciamento' },
                            { key: 'ramo_seguro', label: 'ramo' },
                            { key: 'tipo_seguro', label: 'tipo de seguro' },
                            { key: 'seguradora', label: 'seguradora' },
                            { key: 'origem', label: 'origem' },
                            { key: 'vigencia', label: 'vigência' },
                            { key: 'corretor_id', label: 'produtor' },
                            { key: 'status', label: 'status' },
                            { key: 'indicador', label: 'indicador' },
                            { key: 'ativo', label: 'status ativo' }
                        ];
                        const nomeAutor = (() => {
                            const cor = app.corretores.find(c => String(c.id) === String(app.user?.id));
                            const nome = (cor?.nome_completo || '').trim();
                            return nome ? nome.split(' ')[0] : 'Usuário';
                        })();
                        const linhasMudancas = [];
                        trackedFields.forEach(({ key, label }) => {
                            const antigoNormalizado = normalizeValueLog(key, opAtual?.[key]);
                            const novoNormalizado = normalizeValueLog(key, deal[key]);
                            if (antigoNormalizado === novoNormalizado) {
                                return;
                            }
                            const antigoFmt = formatValueLog(key, opAtual?.[key]) || '—';
                            const novoFmt = formatValueLog(key, deal[key]) || '—';
                            linhasMudancas.push(`${nomeAutor} mudou ${label} de ${antigoFmt} para ${novoFmt}`);
                        });
                        const { error: errOp } = await app.sb.from('oportunidades').update(deal).eq('id', opId);
                        if (errOp) {
                            throw errOp;
                        }
                        if (linhasMudancas.length > 0) {
                            await app.logTimeline(opId, 'Atualização', linhasMudancas.join('\n'), true);
                        }
                    }

                    ui.closeDealModal();

                    if (st === 'ganho' && contatoId) {
                        app.suppressRealtimeBoardSync();
                        await app.sb.from('contatos').update({ is_segurado: true }).eq('id', contatoId);
                        confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#10B981', '#047857'] });
                        await app.loadContatos();
                    }

                    await app.loadData();

                } catch (err) {
                    Swal.fire('Erro ao Salvar', err.message, 'error');
                } finally {
                    btnSubmit.innerHTML = originalBtnText;
                    btnSubmit.disabled = false;
                }
            },

            insertReagendamentoOportunidade: async (opOrigem, reag) => {
                const p0 = ui.produtos[0] || {};
                const contatoId = opOrigem.contato_id;
                const responsavelIdFinal = opOrigem.responsavel_id || null;
                const funilNovos = (app.funis || []).find(f => app.normalizeTipoFunil(f?.tipo_funil) === 'novos');
                const funilDestinoId = funilNovos?.id || opOrigem.funil_id;
                const { data: etapasRows } = await app.sb.from('etapas_funil').select('nome').eq('funil_id', funilDestinoId).order('ordem').limit(1);
                const primeiraEtapa = etapasRows?.[0]?.nome || 'Nova';
                const defaultRamo = app.ramos.length > 0 ? app.ramos[0].nome : 'Automóvel';
                const premioLiq = parseFloat(p0.premio) || parseFloat(opOrigem.premio_liquido) || 0;
                const comissPct = parseFloat(p0.comissao) || parseFloat(opOrigem.comissao_percentual) || 0;
                const agencPct = parseFloat(p0.agenciamento) || parseFloat(opOrigem.agenciamento_percentual) || 0;
                const valorReceitaReag = premioLiq * ((comissPct + agencPct) / 100);

                const retornoReag = reag.retorno || reag.vigencia || opOrigem.retorno || new Date().toISOString().slice(0, 10);
                const deal = {
                    contato_id: contatoId,
                    responsavel_id: responsavelIdFinal,
                    nome_oportunidade: opOrigem.nome_oportunidade || null,
                    vigencia: reag.vigencia || null,
                    retorno: retornoReag,
                    ativo: true,
                    origem: opOrigem.origem,
                    seguradora: opOrigem.seguradora || '',
                    ramo_seguro: p0.ramo || opOrigem.ramo_seguro || defaultRamo,
                    tipo_seguro: 'Novo',
                    premio_liquido: premioLiq,
                    comissao_percentual: comissPct,
                    agenciamento_percentual: agencPct,
                    valor_receita: valorReceitaReag,
                    indicador: opOrigem.indicador || null,
                    corretor_id: opOrigem.corretor_id,
                    etapa_nome: primeiraEtapa,
                    status: 'aberto',
                    funil_id: funilDestinoId
                };
                const { data: ins, error } = await app.sb.from('oportunidades').insert([deal]).select('id');
                if (error) {
                    throw error;
                }
                const nid = ins?.[0]?.id;
                if (nid) {
                    await app.logTimeline(nid, 'Criação', 'Oportunidade reagendada após perda.', true);
                }
                return nid || null;
            },

            marcarGanho: async () => {
                const opId = document.getElementById('opId').value;
