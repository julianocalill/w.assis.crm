                    (o.tipo_seguro != null && String(o.tipo_seguro).trim() !== '') ||
                    (parseFloat(o.comissao_percentual) || 0) !== 0 ||
                    (parseFloat(o.agenciamento_percentual) || 0) !== 0;
                if (temFlat || !o.produtos || !Array.isArray(o.produtos) || o.produtos.length === 0) {
                    const dPremio = parseFloat(o.premio_liquido) || 0;
                    const dComissao = parseFloat(o.comissao_percentual) || 0;
                    const dAgen = parseFloat(o.agenciamento_percentual) || 0;
                    return dPremio * ((dComissao + dAgen) / 100);
                }
                let val = 0;
                o.produtos.forEach(p => {
                    const pPremio = parseFloat(p.premio) || 0;
                    const pComissao = parseFloat(p.comissao) || 0;
                    const pAgen = parseFloat(p.agenciamento) || 0;
                    val += pPremio * ((pComissao + pAgen) / 100);
                });
                return val;
            },

