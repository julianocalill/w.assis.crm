                    ui.renderContatosTable();
                    
                    app.navigate('oportunidades');
                    document.getElementById('loginOverlay').classList.add('hidden');
                    app.setupGlobalSearch();
                    
                    const realtimeDebounceMs = 400;
                    app._realtimeBoardDebounceMs = realtimeDebounceMs;
                    app._realtimePendingEvents = [];
                    const scheduleRealtimeSync = (payload) => {
                        app._realtimePendingEvents.push(payload);
                        if (app._realtimeBoardDebounceTimer) {
                            clearTimeout(app._realtimeBoardDebounceTimer);
                        }
                        app._realtimeBoardDebounceTimer = setTimeout(async () => {
                            app._realtimeBoardDebounceTimer = null;
                            const events = [...app._realtimePendingEvents];
                            app._realtimePendingEvents = [];
                            
                            const now = Date.now();
                            const until = app._suppressRealtimeBoardSyncUntil || 0;
                            const suppressed = until && now < until;

                            if (app._realtimeSyncApplying) {
                                app._realtimePendingEvents.unshift(...events);
                                if (!app._realtimeBoardDebounceTimer) {
                                    app._realtimeBoardDebounceTimer = setTimeout(() => scheduleRealtimeSync({ _dummy: true }), 200);
                                }
                                return;
                            }

                            if (suppressed) {
                                return;
                            }
                            app._realtimeSyncApplying = true;
                            
                            try {
                                const validEvents = events.filter(e => !e._dummy);
                                if (validEvents.length === 0) return;

                                const isContatoChanged = validEvents.some(e => e.table === 'contatos');
                                if (isContatoChanged) {
                                    await app.loadContatos();
                                }
                                
                                const viewListActive = !document.getElementById('board-lista').classList.contains('hidden');
                                if (viewListActive) {
                                    // Se estiver na lista ou precisar atualizar tudo
                                    await app.loadData();
                                } else {
                                    // Modo incremental no Kanban
                                    const opEvents = validEvents.filter(e => e.table === 'oportunidades');
                                    let fullReloadNeeded = false;
                                    
                                    for (const ev of opEvents) {
                                        try {
                                            app.syncKanbanOpFromRecord(ev);
                                        } catch (err) {
                                            console.warn('[Realtime] Falha no sync incremental, forçando reload.', err);
                                            fullReloadNeeded = true;
                                            break;
                                        }
                                    }
                                    
                                    if (fullReloadNeeded) {
                                        await app.loadData();
                                    }
                                }
                            } catch (e) {
                                console.error('[Realtime] Falha ao sincronizar:', e);
                            } finally {
                                app._realtimeSyncApplying = false;
                            }
                        }, realtimeDebounceMs);
                    };

                    const realtimeChannel = app.sb.channel('db-changes')
                        .on('postgres_changes', { event: '*', schema: 'public', table: 'oportunidades' }, scheduleRealtimeSync)
                        .on('postgres_changes', { event: '*', schema: 'public', table: 'contatos' }, scheduleRealtimeSync);

                    realtimeChannel.subscribe((status, err) => {
                        if (status === 'SUBSCRIBED') {
                            console.info('[Realtime] Canal db-changes inscrito (oportunidades, contatos).');
                        } else if (status === 'CHANNEL_ERROR' || status === 'TIMED_OUT' || status === 'CLOSED') {
                            console.warn('[Realtime]', status, err || '');
                        }
                    });

                    if (!app._visibilitySyncBound) {
                        app._visibilitySyncBound = true;
                        document.addEventListener('visibilitychange', () => {
                            if (document.visibilityState !== 'visible' || !app.sb || !app.user) {
                                return;
                            }
                            (async () => {
                                try {
                                    await app.loadContatos();
                                    await app.loadData();
                                } catch (e) {
                                    console.error('[Visibilidade] Falha ao sincronizar:', e);
                                }
                            })();
                        });
                    }

                } catch (error) {
                    app.showLoginLoading(false);
                    console.error("ERRO CRÍTICO INICIALIZAÇÃO:", error);
                    Swal.fire({
                        title: 'Aviso',
                        text: 'O sistema carregou, mas algumas configurações falharam. Certifique-se de ter rodado o Script SQL.',
                        icon: 'warning'
                    });
                }
            },

