            normalizeDigits: (v) => (v || '').toString().replace(/\D/g, ''),

            /** Somente dígitos para validação de documento (CPF/CNPJ). */
            normalizeDocumento: (v) => app.normalizeDigits(v),

            isValidCPF: (digits) => {
                const d = typeof digits === 'string' ? digits : '';
                if (!d || d.length !== 11 || /^(\d)\1{10}$/.test(d)) {
                    return false;
                }
                let sum = 0;
                for (let i = 0; i < 9; i++) {
                    sum += parseInt(d[i], 10) * (10 - i);
                }
                let r = sum % 11;
                const dv1 = r < 2 ? 0 : 11 - r;
                if (dv1 !== parseInt(d[9], 10)) {
                    return false;
                }
                sum = 0;
                for (let i = 0; i < 10; i++) {
                    sum += parseInt(d[i], 10) * (11 - i);
                }
                r = sum % 11;
                const dv2 = r < 2 ? 0 : 11 - r;
                return dv2 === parseInt(d[10], 10);
            },

            isValidCNPJ: (digits) => {
                const d = typeof digits === 'string' ? digits : '';
                if (!d || d.length !== 14 || /^(\d)\1{13}$/.test(d)) {
                    return false;
                }
                const w1 = [5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
                let sum = 0;
                for (let i = 0; i < 12; i++) {
                    sum += parseInt(d[i], 10) * w1[i];
                }
                let r = sum % 11;
                const dv1 = r < 2 ? 0 : 11 - r;
                if (dv1 !== parseInt(d[12], 10)) {
                    return false;
                }
                const w2 = [6, 5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
                sum = 0;
                for (let i = 0; i < 13; i++) {
                    sum += parseInt(d[i], 10) * w2[i];
                }
                r = sum % 11;
                const dv2 = r < 2 ? 0 : 11 - r;
                return dv2 === parseInt(d[13], 10);
            },

            /**
             * Valida documento brasileiro para cadastro.
             * @returns {string|null} Mensagem de erro ou null se OK.
             */
            documentoCadastroError: (valorCampo, opts = {}) => {
                const obrigatorio = !!opts.obrigatorio;
                const prefixo = opts.prefixo ? String(opts.prefixo).trim() : '';
                const d = app.normalizeDocumento(valorCampo);
                const pre = prefixo ? `${prefixo}: ` : '';
                if (!d) {
                    return obrigatorio ? `${pre}CPF/CNPJ é obrigatório.` : null;
                }
                if (d.length === 11) {
                    return app.isValidCPF(d) ? null : `${pre}CPF inválido (verifique os dígitos).`;
                }
                if (d.length === 14) {
                    return app.isValidCNPJ(d) ? null : `${pre}CNPJ inválido (verifique os dígitos).`;
                }
                return `${pre}Informe CPF (11 dígitos) ou CNPJ (14 dígitos).`;
            },

