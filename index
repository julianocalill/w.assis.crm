                        const pAgen = parseFloat(p.agenciamento) || 0;
                        
                        tPremio += pPremio; 
                        tReceita += pPremio * ((pComissao + pAgen) / 100); 
                    });
                    
                    let mComissao = tPremio > 0 ? (tReceita / tPremio) * 100 : 0;
                    
                    let etapa = document.getElementById('opEtapaHeader').value || (app.etapas[0] ? app.etapas[0].nome : 'Nova');
                    
