            updateHistoricoOpsSortIcons: () => {
                const map = {
                    vigencia: 'hist-sort-vigencia',
                    ramo: 'hist-sort-ramo',
                    tipo: 'hist-sort-tipo',
                    etapa: 'hist-sort-etapa',
