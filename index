                if (!app.oportunidades || app.oportunidades.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="${colCount}" class="px-6 py-10 text-center text-textMuted font-medium">Nenhuma oportunidade com esses filtros.</td></tr>`;
                    return;
                }

                tbody.innerHTML = app.oportunidades.map(d => {
                    const ramosText = ui.oportunidadeRamoExibicao(d);

                    let bgRowClass = 'hover:bg-slate-50 border-b border-border';
                    let textRetornoClass = 'text-textMuted font-medium';
                    
                    if (d.retorno && d.status === 'aberto' && !d.excluido) {
                        const hoje = new Date(); hoje.setHours(0,0,0,0);
                        const [ano, mes, dia] = d.retorno.split('-');
                        const dataRet = new Date(ano, mes - 1, dia); dataRet.setHours(0,0,0,0);
                        
                        if (dataRet < hoje) {
                            bgRowClass = 'bg-red-50/50 hover:bg-red-50 border-b border-red-100';
                            textRetornoClass = 'text-red-600 font-bold';
                        } else if (dataRet.getTime() === hoje.getTime()) {
                            bgRowClass = 'bg-blue-50/50 hover:bg-blue-50 border-b border-blue-200';
                            textRetornoClass = 'text-blue-700 font-bold';
                        }
                    }
                    
                    if (d.status === 'ganho') {
                        textRetornoClass = 'text-emerald-600 font-bold';
                    }
                    if (d.status === 'perdido') {
                        textRetornoClass = 'text-slate-400 line-through';
                    }
                    if (d.excluido) {
                        bgRowClass = 'bg-slate-100/80 hover:bg-slate-100 border-b border-slate-200';
                    }

                    const dtRetorno = d.retorno ? new Date(d.retorno + 'T12:00:00').toLocaleDateString('pt-BR') : '-';
                    const dtVigencia = d.vigencia ? new Date(d.vigencia + 'T12:00:00').toLocaleDateString('pt-BR') : '-';

                    const st = d.status || 'aberto';
                    let statusBadgeClass = 'bg-slate-100 text-slate-700';
                    let statusLabel = 'Aberto';
                    if (st === 'ganho') {
                        statusBadgeClass = 'bg-emerald-100 text-emerald-700';
                        statusLabel = 'Ganho';
                    } else if (st === 'perdido') {
                        statusBadgeClass = 'bg-red-100 text-red-700';
                        statusLabel = 'Perdido';
                    } else if (st === 'pendente') {
                        statusBadgeClass = 'bg-amber-50 text-amber-800';
                        statusLabel = 'Pendente';
                    }

                    const statusCellInner = d.excluido
