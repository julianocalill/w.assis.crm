                    </div>
                `).join('');
            },

            addProduto: () => {
                const defaultRamo = app.ramos.length > 0 ? app.ramos[0].nome : 'Automóvel';
                
                ui.produtos.push({ 
                    id: Date.now(), 
                    ramo: defaultRamo, 
                    tipo: 'Novo', 
                    premio: 0, 
                    comissao: 0, 
                    agenciamento: 0 
                });
                
                ui.renderProdutos();
            },
            
            removeProduto: (index) => {
                ui.produtos.splice(index, 1); 
                ui.renderProdutos();
            },
            
            updateProduto: (index, field, val) => {
                if (field === 'ramo' || field === 'tipo') { 
                    ui.produtos[index][field] = val; 
                } else { 
                    ui.produtos[index][field] = parseFloat(val) || 0; 
                }
                
                ui.calcTotalProdutos();
                
                const row = document.getElementById('produtos-list').children[index];
                
                if (row) {
                    const premio = parseFloat(ui.produtos[index].premio) || 0;
                    const comissao = parseFloat(ui.produtos[index].comissao) || 0;
                    const agenciamento = parseFloat(ui.produtos[index].agenciamento) || 0;
                    const rec = premio * ((comissao + agenciamento) / 100);
                    row.querySelector('.receita-text').innerText = formatBRL(rec);
                }
            },
            
            calcTotalProdutos: () => {
                let tPremio = 0; 
                let tReceita = 0;
                
                ui.produtos.forEach(p => { 
                    const premio = parseFloat(p.premio) || 0;
                    const comissao = parseFloat(p.comissao) || 0;
                    const agenciamento = parseFloat(p.agenciamento) || 0;
                    
                    tPremio += premio; 
                    tReceita += (premio * ((comissao + agenciamento) / 100)); 
                });
                
                document.getElementById('total-premio-geral').innerText = formatBRL(tPremio);
                document.getElementById('total-receita-geral').innerText = formatBRL(tReceita);
            },
            
            renderProdutos: () => {
                const container = document.getElementById('produtos-list');
                const ramoOptionsHtml = app.ramos.map(r => `<option value="${r.nome}">${r.nome}</option>`).join('');

