            buscarOportunidadesGlobalSearch: (termo) => {
                const qText = app.normalizeText(termo);
                const qDigits = app.normalizeDigits(termo);
                if (!qText && !qDigits) {
                    return [];
                }
                if (!qDigits && qText.length < 2) {
                    return [];
                }

                const scoreOp = (op) => {
                    let score = 0;
                    const nomeSeg = app.normalizeText(ui.nomeSeguradoExibicao(op));
                    const ct = op.contato_id ? app.contatos.find(c => c.id === op.contato_id) : null;
                    const docCt = app.normalizeDigits(op.documento_contato ?? ct?.documento);
                    const telCt = app.normalizeDigits(op.telefone_contato ?? ct?.telefone);
                    const nomeCt = app.normalizeText(ct?.nome || '');
                    const nomeResp = app.normalizeText(op.nome_responsavel || '');
                    const docResp = app.normalizeDigits(op.documento_responsavel || '');
                    const telResp = app.normalizeDigits(op.telefone_responsavel || '');

                    if (qDigits && (qDigits.length === 11 || qDigits.length === 14)) {
                        if (docCt === qDigits || docResp === qDigits) {
                            score = Math.max(score, 100);
                        }
                    }
                    if (qDigits && telCt && (telCt === qDigits || (qDigits.length >= 8 && telCt.startsWith(qDigits)))) {
                        score = Math.max(score, 90);
                    }
                    if (qDigits && telResp && (telResp === qDigits || (qDigits.length >= 8 && telResp.startsWith(qDigits)))) {
                        score = Math.max(score, 88);
                    }
                    if (qText && nomeSeg.includes(qText)) {
                        score = Math.max(score, 85);
                    }
                    const nomeTituloOp = app.normalizeText(op.nome_oportunidade || '');
                    if (qText && nomeTituloOp.includes(qText)) {
                        score = Math.max(score, 86);
                    }
                    if (qText && nomeCt && nomeCt.includes(qText)) {
                        score = Math.max(score, 82);
                    }
                    if (qText && nomeResp.includes(qText)) {
                        score = Math.max(score, 78);
                    }
                    if (qDigits && docCt && docCt.includes(qDigits)) {
                        score = Math.max(score, 70);
                    }
                    if (qDigits && telCt && telCt.includes(qDigits)) {
                        score = Math.max(score, 68);
                    }
                    if (qDigits && docResp && docResp.includes(qDigits)) {
                        score = Math.max(score, 67);
                    }
                    if (qDigits && telResp && telResp.includes(qDigits)) {
                        score = Math.max(score, 66);
                    }
                    return score;
                };

                return (app.oportunidades || [])
                    .filter(op => String(op.funil_id) === String(config.activePipeline))
                    .map(op => ({ op, score: scoreOp(op) }))
                    .filter(x => x.score > 0)
                    .sort((a, b) => b.score - a.score || String(ui.tituloOportunidadeExibicao(a.op) || '').localeCompare(String(ui.tituloOportunidadeExibicao(b.op) || ''), 'pt-BR'))
                    .slice(0, 8)
                    .map(x => x.op);
            },

