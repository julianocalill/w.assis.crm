                if (!opId) return;

                const opEx = app.oportunidades.find(o => o.id == opId);
                if (opEx && (opEx.status === 'ganho' || opEx.status === 'perdido')) {
                    return;
                }

                const tf = ui.getTipoFunilDealModalContext();
                if (tf === 'pos_venda') {
