                }
                const errDocG = app.documentoCadastroError(document.getElementById('opDocumento').value, { obrigatorio: true, prefixo: 'Segurado' });
                if (errDocG) {
                    return Swal.fire('Atenção', errDocG, 'warning');
                }
                if (!(document.getElementById('opNome').value || '').trim()) {
                    return Swal.fire('Atenção', 'Informe o nome do segurado para fechar o negócio.', 'warning');
                }

                const tf = ui.getTipoFunilDealModalContext();
                if (tf === 'pos_venda') {
                    return Swal.fire('Pós-venda', 'O fluxo de fechamento para funil de pós-venda será disponibilizado na fase 2.', 'info');
                }

                const btn = document.getElementById('btnGanharDeal');
                const prevBtn = btn.innerHTML;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
                btn.disabled = true;

                try {
                    const emailStep = await closeFlowModals.openEmailProposta();
                    if (emailStep.cancelled) {
                        btn.innerHTML = prevBtn;
                        btn.disabled = false;
                        return;
                    }
                    if (!emailStep.email || emailStep.email.skipped) {
                        btn.innerHTML = prevBtn;
                        btn.disabled = false;
                        return;
                    }

                    const opAtual = app.oportunidades.find(o => o.id == opId);
                    const ultima = app.getUltimaEtapaNome();
                    const etapaGanho = ultima || (opAtual && opAtual.etapa_nome) || (app.etapas[0] && app.etapas[0].nome) || 'Nova';
                    app.suppressRealtimeBoardSync();
                    await app.sb.from('oportunidades').update({
                        status: 'ganho',
                        etapa_nome: etapaGanho,
                        data_fechamento: new Date().toISOString()
                    }).eq('id', opId);
                    
                    app.suppressRealtimeBoardSync();
                    await app.sb.from('contatos').update({ is_segurado: true }).eq('id', contatoId);
                    await app.logTimeline(opId, 'Movimentação', `Negócio GANHO com sucesso!`, true);
                    
                    const { data: opRowArr } = await app.sb.from('oportunidades').select('*').eq('id', opId);
                    const opRow = opRowArr?.[0];
                    const { data: contArr } = await app.sb.from('contatos').select('*').eq('id', contatoId);
                    const cData = contArr?.[0];

                    ui.closeDealModal();
                    confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#10B981', '#047857'] });
                    
                    await app.loadContatos();
                    await app.loadData();
                    
                    const n8nUrl = app.appConfig && app.appConfig.n8n_deal_webhook;
                    if (n8nUrl) {
                        fetch(n8nUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                event: 'fechamento',
                                outcome: 'ganho',
                                tipo_funil: tf,
                                fila: { emailProposta: emailStep.email },
                                oportunidade: opRow,
                                contato: cData
                            })
                        }).catch(e => console.error('Webhook N8N falhou', e));
                    }
                    
                } catch(e) {
                    Swal.fire('Erro', e.message, 'error');
                } finally {
                    btn.innerHTML = prevBtn;
                    btn.disabled = false;
                }
            },

            marcarPerdido: async () => {
