                            rec = dPremio * ((dComissao + dAgen) / 100);
                        }
                        
                        const dtFechamento = o.data_fechamento ? new Date(o.data_fechamento).toLocaleDateString('pt-BR') : new Date(o.criado_em).toLocaleDateString('pt-BR');
                        const produtor = o.nome_corretor || '-';
                        
                        return `
                        <tr class="hover:bg-slate-50 transition cursor-pointer" onclick="ui.editDealById(${o.id})">
                            <td class="px-4 py-3 text-textMuted text-xs font-mono">${dtFechamento}</td>
                            <td class="px-4 py-3 font-bold text-textMain">${o.nome_segurado}</td>
                            <td class="px-4 py-3 text-textMuted text-xs">${ramosText}</td>
                            <td class="px-4 py-3 text-textMuted text-xs">${produtor}</td>
                            <td class="px-4 py-3 font-extrabold text-emerald-600 text-right">${formatBRL(rec)}</td>
                        </tr>
                        `;
                    }).join('');
                }
            },

            createPipeline: async () => {
                const nome = document.getElementById('newPipeName').value;
                if (!nome) {
                    return Swal.fire('Atenção', 'Digite um nome para o funil.', 'warning');
                }
                
                try {
                    const {data, error} = await app.sb.from('funis').insert([{nome}]).select();
                    if (error) {
                        throw error;
                    }
                    
                    document.getElementById('newPipeName').value = '';
                    setTimeout(() => app.switchPipeline(data[0].id), 1500);
                } catch(e) {
                    Swal.fire('Erro', e.message, 'error');
                }
            },
            
            createStage: async () => {
                const nome = document.getElementById('newStageName').value;
                const cor = document.getElementById('newStageColor').value;
                if (!nome) {
                    return Swal.fire('Atenção', 'Digite o nome da etapa', 'warning');
                }
                
                try {
                    await app.sb.from('etapas_funil').insert([{ funil_id: config.activePipeline, nome, cor, ordem: app.etapas.length + 1 }]);
                    document.getElementById('newStageName').value = '';
                    await app.loadData();
                    window.ui.openSettingsModal();
                } catch(e) {
                    Swal.fire('Erro', e.message, 'error');
                }
            },
            
            editStagePrompt: async (id, oldName, oldColor) => {
                const { value: v } = await Swal.fire({
                    title: 'Editar Etapa',
                    html: `
                        <input id="sw-n" class="w-full border border-border p-3 mb-4 rounded-lg outline-none focus:border-primary" value="${oldName}">
                        <select id="sw-c" class="w-full border border-border p-3 rounded-lg outline-none cursor-pointer focus:border-primary">
                            <option value="bg-blue-500" ${oldColor==='bg-blue-500'?'selected':''}>Azul</option>
                            <option value="bg-green-600" ${oldColor==='bg-green-600'?'selected':''}>Verde</option>
                            <option value="bg-yellow-500" ${oldColor==='bg-yellow-500'?'selected':''}>Amarelo</option>
                            <option value="bg-purple-500" ${oldColor==='bg-purple-500'?'selected':''}>Roxo</option>
                            <option value="bg-orange-500" ${oldColor==='bg-orange-500'?'selected':''}>Laranja</option>
                            <option value="bg-red-600" ${oldColor==='bg-red-600'?'selected':''}>Vermelho</option>
                            <option value="bg-slate-400" ${oldColor==='bg-slate-400'?'selected':''}>Cinza</option>
                        </select>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Salvar',
                    cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#0263E0',
                    preConfirm: () => ({ n: document.getElementById('sw-n').value, c: document.getElementById('sw-c').value })
                });
                
                if (v && v.n) {
                    try {
                        await app.sb.from('etapas_funil').update({ nome: v.n, cor: v.c }).eq('id', id);
                        
                        if (oldName !== v.n) {
                            await app.sb.from('oportunidades').update({ etapa_nome: v.n }).eq('etapa_nome', oldName).eq('funil_id', config.activePipeline);
                        }
                        
                        await app.loadData();
                        window.ui.openSettingsModal();
                    } catch(e) {
                        Swal.fire('Erro', e.message, 'error');
                    }
                }
            },
            
            updateStagesOrder: async () => {
                const els = document.getElementById('stages-list-manager').querySelectorAll('[data-id]');
                const u = [];
                
                els.forEach((el, i) => {
                    u.push({ id: el.dataset.id, ordem: i + 1 });
                });
                
                try {
                    for (const o of u) {
                        await app.sb.from('etapas_funil').update({ ordem: o.ordem }).eq('id', o.id);
                    }
                    await app.loadData();
                } catch(e) {
                    console.error("Ordem error", e);
                }
            },
            
            deleteStage: async (id) => {
                if (confirm('Excluir esta etapa do funil? Oportunidades aqui ficarão sem coluna visível.')) {
                    try {
                        await app.sb.from('etapas_funil').delete().eq('id', id);
                        await app.loadData();
                        window.ui.openSettingsModal();
                    } catch(e) {
                        Swal.fire('Erro', e.message, 'error');
                    }
                }
            },
            
            renderManagerStages: () => {
                const list = document.getElementById('stages-list-manager');
                
                if (app.etapas.length === 0) {
                    list.innerHTML = '<div class="p-6 text-center text-textMuted bg-slate-50 border border-dashed rounded-lg">Funil sem etapas configuradas.</div>';
                } else {
                    list.innerHTML = app.etapas.map(s => `
                        <div class="flex justify-between items-center bg-white border border-border p-3 mb-2 rounded-lg shadow-sm" data-id="${s.id}">
                            <div class="flex items-center gap-3">
                                <div class="handle cursor-grab text-slate-300 hover:text-textMain transition px-1"><i class="fa-solid fa-grip-lines-vertical"></i></div>
                                <span class="w-3 h-3 rounded-full ${s.cor}"></span>
                                <span class="font-bold text-textMain">${s.nome}</span>
                            </div>
                            <div>
                                <button onclick="app.editStagePrompt(${s.id}, '${s.nome}', '${s.cor}')" class="text-slate-400 hover:text-primary transition mr-3"><i class="fa-solid fa-pen"></i></button>
                                <button onclick="app.deleteStage(${s.id})" class="text-slate-400 hover:text-red-500 transition"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                    `).join('');
                }
                
                if (window.managerSortable) {
                    window.managerSortable.destroy();
                }
                
                window.managerSortable = new Sortable(list, {
                    animation: 150,
                    handle: '.handle',
                    ghostClass: 'bg-primary/5',
                    onEnd: function (evt) {
                        if (evt.oldIndex !== evt.newIndex) {
                            window.app.updateStagesOrder();
                        }
                    }
                });
            }
        };

        // Inicia o app quando o DOM estiver pronto
        document.addEventListener('DOMContentLoaded', app.init);
    </script>
</body>
</html>
